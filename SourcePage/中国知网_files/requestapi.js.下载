function createListModule(config) {
  // 每个模块的私有变量（独立隔离，互不干扰）
  let fullData = []; // 该模块的21条完整数据
  let currentPage = 1; // 该模块的当前页码（1-7）
  const pageSize = 3; // 固定每页3条
  const maxPage = 7; // 固定7页（21/3）
  const autoChangeInterval = 5000; // 自动切换间隔（5秒）
  let autoChangeTimer = null; // 每个模块独立的定时器（关键：避免冲突）
  let isChangeAble = true; // 是否可点击「换一换」，初始可点击
  const clickThrottleTime = 3000; // 节流时间：3秒（3000毫秒）

  // 解析PT字段的工具函数
  function parsePT(ptStr) {
    if (!ptStr) return Date.parse(new Date()); // 无PT时返回当前UTC时间戳
    try {
      const utcDate = new Date(ptStr.replace(/-/g, "/"));
      const utcTimestamp = utcDate.getTime();
      return utcTimestamp;
    } catch (e) {
      return Date.parse(new Date());
    }
  }

  // 检查所有模块PT是否收集完成，完成后比较选出最近的
  function checkAndComparePT() {
    const allCollected = Object.values(modulePTTimes).every(
      (val) => val !== null,
    );
    if (!allCollected) {
      //  console.log("未收集完所有PT，等待中...");
      return;
    }

    // 筛选有效时间戳，找出最大的（离现在最近）
    const validPTs = Object.values(modulePTTimes).filter((val) => val !== null);
    const latestPT =
      validPTs.length > 0 ? Math.max(...validPTs) : Date.parse(new Date());

    // 格式化时间
    latestPTFormatted = indexPage.dateDif(latestPT);
    $("#latest-time").text(latestPTFormatted);

    // 调试日志
    console.log("三个模块PT时间戳：", modulePTTimes);
    console.log("最近的PT时间戳：", latestPT);
    console.log("格式化后展示：", latestPTFormatted);
  }

  // 1. 请求模块专属接口数据
  function fetchData() {
    $.ajax({
      url: config.apiUrl, // 不同模块的接口URL
      type: "GET",
      dataType: "json",
      timeout: 10000,
      xhrFields: { withCredentials: false },
      crossDomain: true,
      beforeSend: () => console.log(`[${config.listId}] 数据请求中...`),
      success: (data) => {
        if (data.code === 0 && data?.data?.data.length > 0) {
          // 复用公共数据处理函数
          fullData = data.data.data.map((item) =>
            getDataPublicDeal(
              item.metadata,
              item.relations,
              item.source,
              item.authors,
              item.affiliations,
              item.keywords,
              item.funds,
              item.metrics,
              item.related,
              item.issues,
              null,
              item.repository,
            ),
          );
          console.log("fullData", fullData, config.listId);
        } else {
          if (config.listId === "#zrkx-list") {
            fullData = zrkxlist;
          } else if (config.listId === "#sxll-list") {
            fullData = sxlllist;
          } else if (config.listId === "#rwsk-list") {
            fullData = rwsklist;
          }
        }
        currentPage = 1;
        // 解析第一条数据的PT字段
        const firstItem = fullData[0]; // 取接口返回的第一条原始数据
        if (firstItem?.PT) {
          // 假设PT字段在metadata里，根据实际结构调整
          // 1. 解析PT为时间戳
          const ptTimestamp = parsePT(firstItem.PT);
          // 2. 根据模块标识存储到全局
          if (config.listId === "#zrkx-list") {
            modulePTTimes.zrkx = ptTimestamp;
          } else if (config.listId === "#sxll-list") {
            modulePTTimes.sxll = ptTimestamp;
          } else if (config.listId === "#rwsk-list") {
            modulePTTimes.rwsk = ptTimestamp;
          }
          // 3. 检查是否所有模块PT都收集完成，完成则比较
          checkAndComparePT();
        }
        renderList(); // 数据成功后渲染
        startAutoChange(); // 数据加载完成后，启动自动切换（关键）
      },
      error: (jqXHR, textStatus) => {
        // const errMsg =
        //   textStatus === "timeout"
        //     ? "请求超时"
        //     : `请求失败（状态码：${jqXHR.status}）`;
        // if (config.listId === "#zrkx-list") {
        //   modulePTTimes.zrkx = Date.parse(new Date());
        // } else if (config.listId === "#sxll-list") {
        //   modulePTTimes.sxll = Date.parse(new Date());
        // } else if (config.listId === "#rwsk-list") {
        //   modulePTTimes.rwsk = Date.parse(new Date());
        // }
        // checkAndComparePT();
        if (config.listId === "#zrkx-list") {
          fullData = zrkxlist;
        } else if (config.listId === "#sxll-list") {
          fullData = sxlllist;
        } else if (config.listId === "#rwsk-list") {
          fullData = rwsklist;
        }
        currentPage = 1;
        // 解析第一条数据的PT字段
        const firstItem = fullData[0]; // 取接口返回的第一条原始数据
        if (firstItem?.PT) {
          // 假设PT字段在metadata里，根据实际结构调整
          // 1. 解析PT为时间戳
          const ptTimestamp = parsePT(firstItem.PT);
          // 2. 根据模块标识存储到全局
          if (config.listId === "#zrkx-list") {
            modulePTTimes.zrkx = ptTimestamp;
          } else if (config.listId === "#sxll-list") {
            modulePTTimes.sxll = ptTimestamp;
          } else if (config.listId === "#rwsk-list") {
            modulePTTimes.rwsk = ptTimestamp;
          }
          // 3. 检查是否所有模块PT都收集完成，完成则比较
          checkAndComparePT();
        }
        renderList(); // 数据成功后渲染
        startAutoChange(); // 数据加载完成后，启动自动切换（关键）
      },
    });
  }

  // 2. 渲染当前模块的列表（序号、数据正确关联）
  function renderList() {
    const $list = $(config.listId); // 匹配当前模块的列表ID
    $list.empty();

    // 计算当前页数据范围
    const startIndex = (currentPage - 1) * pageSize;
    const endIndex = startIndex + pageSize;
    const showData = fullData.slice(startIndex, endIndex);

    // 渲染3条数据（序号自动计算，换一换后更新）
    showData.forEach((item, index) => {
      // 🌟 处理作者数据：兼容数组为空/无title的情况，避免报错
      const firstAuthor = item.AUTHORS?.[0] || {}; // 取第一个作者对象，无则置空对象
      const authorTitle = firstAuthor.title || "未知作者"; // 取第一个作者的title，无则显示"未知作者"
      const authorUrl = firstAuthor.ABSTRACTUrl || "javascript:;"; // 作者跳转链接，无则禁用跳转

      const authors = item.AUTHORS || [];
      const authorTitles = authors
        .map((author) => author.title || "")
        .filter((title) => title);
      let authorStr = "未知作者";
      if (authorTitles.length > 0) {
        authorStr =
          authorTitles.length > 3
            ? `${authorTitles.slice(0, 3).join(",")},等`
            : authorTitles.join(",");
      }
      //  拼接title格式：作者.标题[J/OL].来源.（兼容空值）
      const ti = item.TI || "";
      const ly = item.LY || "";
      const fullTitle = `${authorStr}.${ti}[J/OL].${ly}.`
        .replace(/\.\[J\/OL\]\.\./g, "[J/OL].") // 处理来源为空的多余点
        .replace(/\.\[J\/OL\]\./g, "[J/OL].")
        .replace(/未知作者\./g, authorStr === "未知作者" ? "" : "未知作者."); // 处理无作者情况

      const $li = $(`
        <li class="item">
          <a href="javascript:;" target="_blank"> <!-- 外层a标签取消跳转 -->
            <span class="no">${
              startIndex + index + 1
            }</span> <!-- 序号：1-3/4-6/...循环 -->
            <p class="i-content">
              <span class="author"><a href="${authorUrl}" target="_blank">${authorTitle}</a></span>：
              <span class="ti"><a href="${
                item.ABSTRACTUrl
              }" target="_blank" title="${fullTitle}">${item.TI}</a></span>
            </p>
          </a>
        </li>
      `);
      $list.append($li);
    });
  }

  // 3. 切换到下一页（手动点击和自动切换共用）
  function goToNextPage() {
    if (fullData.length === 0) return;
    currentPage = currentPage >= maxPage ? 1 : currentPage + 1;
    renderList();
    resetAutoChangeTimer(); // 切换后重置定时器（关键：手动/自动切换都触发）
  }

  // 4. 启动自动切换
  function startAutoChange() {
    // 先清除已有定时器（避免重复创建）
    clearAutoChangeTimer();
    // 10秒后自动切换下一页
    autoChangeTimer = setInterval(() => {
      goToNextPage();
    }, autoChangeInterval);
  }

  // 5. 清除自动切换定时器
  function clearAutoChangeTimer() {
    if (autoChangeTimer) {
      clearInterval(autoChangeTimer);
      autoChangeTimer = null;
    }
  }

  // 6. 重置自动切换定时器（手动点击后重新计时10秒）
  function resetAutoChangeTimer() {
    startAutoChange(); // 清除旧定时器 + 启动新定时器 = 重新计时
  }

  // 7. 绑定当前模块的"换一换"事件（避免冲突）
  function bindChangeEvent() {
    // 只绑定当前模块容器内的"换一换"按钮
    $(config.containerSelector)
      .find(".title-right")
      .on("click", function () {
        if (!isChangeAble) {
          console.log(`换一换3秒冷却中，请勿频繁点击`);
          return;
        }
        // 点击后立即锁定
        isChangeAble = false;
        fetchData(); // 调接口
        setTimeout(() => {
          isChangeAble = true;
        }, clickThrottleTime);
      });
  }

  // 模块初始化入口
  return {
    init: () => {
      fetchData();
      bindChangeEvent();
    },
    // 可选：暴露销毁方法（页面卸载时调用，避免内存泄漏）
    destroy: () => {
      clearAutoChangeTimer();
      $(config.containerSelector).find(".title-right").off("click");
    },
  };
}


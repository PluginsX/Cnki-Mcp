// === 核心工具函数 ===
/**
 * 构建第二部分跳转所需的所有参数（包含range、net、ds、question、action等）
 * @param {string} actionType - 动作类型：doc/img/空（检索）
 * @param {string} area - 区域标识：ai/search（默认取当前owner）
 * @returns {string} 拼接好的参数字符串
 */
window.buildAIJumpParams = function (
  actionType = "",
  area = window.uploadState.owner,
  customQuestion = "", // 接收外部传入的默认文案
) {
  // 新增area参数
  let _inputValue = "";
  let urlParams = new URLSearchParams();
  const areaState = window.uploadState[area]; // 读取对应区域的状态

  // 1. 检索区（search）：读取检索区的docid
  if (area === "search") {

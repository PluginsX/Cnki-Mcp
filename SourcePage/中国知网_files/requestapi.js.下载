// 删除文件（兼容区域参数，删除对应区域的docid）
function deleteFile(area = "ai") {
  // 新增area参数
  // 读取对应区域的状态（先完整读取，方便判断场景）
  const areaState = window.uploadState[area] || {
    fileParams: { docid: "", uploadPercentage: 0 },
    uploadStatus: "notUpload",
  };
  const docid = areaState.fileParams.docid;

  // ===== 场景1：无 docid（上传失败）—— 仅前端清空，无需调用后端接口 =====
  if (!docid) {
    // 直接清空对应区域的DOM（和上传成功场景的DOM清空逻辑一致）
    if (area === "ai") {
      const txtBoxContainer = document.getElementById("txtBoxContainer");
      if (txtBoxContainer) txtBoxContainer.style.display = "none";
      const fileBox = document.getElementById("uploadFileBox");
      if (fileBox) {
        fileBox.style.display = "none";
        // 额外：移除上传失败的样式类，避免残留
        fileBox.classList.remove("uploaded-failed");
      }
      setAiTextareaRows(3);
    } else if (area === "search") {
      const txtBoxContainer = document.getElementById("searchTxtBoxContainer");
      if (txtBoxContainer) txtBoxContainer.style.display = "none";
      const fileBox = document.getElementById("searchUploadFileBox");
      if (fileBox) {
        fileBox.style.display = "none";
        fileBox.classList.remove("uploaded-failed");
      }
    }

    // 重置对应区域的状态（和上传成功场景的状态重置逻辑一致）
    window.uploadState[area] = {
      uploadStatus: "notUpload",
      fileParams: {
        mimetype: "",
        fileSizeInKB: "",
        doctitle: "",
        docid: "",
        uploadPercentage: 0,
      },
      fileList: [],
      timer: null,
      uploadTip: "",
      clickBtnType: "",
    };
    // 清空对应区域输入框
    const inputId = area === "ai" ? "txt_SearchText_ai" : "txt_SearchText";
    const inputDom = document.getElementById(inputId);
    if (inputDom) inputDom.value = "";

    // 刷新显示、提示成功、更新banner高度
    updateFileDisplay(area);
    $message.success("删除成功");
    updateBannerHeight();
    // ===== 更新检索区DOM（隐藏DBFieldBox/切换placeholder） =====
    if (area === "search") {
      updateSearchDomByFileState();
    }
    // 聚焦到对应输入框（兼容DOM存在的情况）
    if (inputDom) {
      inputDom.focus(); // 光标聚焦
    }
    // 无docid场景执行完毕，直接返回（不执行后续后端接口逻辑）
    return;
  }

  // ===== 场景2：有 docid（上传成功）—— 调用后端接口删除 =====
  fetch(
    URL_CONFIG.uploadUrl + `/aipower/upload/file/remove?docid=${docid}`, // 对应区域的docid
    {
      method: "GET",
      credentials: "include",
      // signal: AbortSignal.timeout(10000),
      signal: getTimeoutSignal(10000),
    },
  )
    .then((response) => response.json())
    .then((res) => {
      if (res.message === "success") {
        // 清空对应区域的DOM（原有逻辑不变）
        if (area === "ai") {
          const txtBoxContainer = document.getElementById("txtBoxContainer");
          txtBoxContainer.style.display = "none";
          const fileBox = document.getElementById("uploadFileBox");
          fileBox.style.display = "none";
          setAiTextareaRows(3);
        } else if (area === "search") {
          const txtBoxContainer = document.getElementById(
            "searchTxtBoxContainer",
          );
          txtBoxContainer.style.display = "none";
          const fileBox = document.getElementById("searchUploadFileBox");
          fileBox.style.display = "none";
        }

        // 重置对应区域的状态（核心：不重置另一区域）
        window.uploadState[area] = {
          uploadStatus: "notUpload",
          fileParams: {
            mimetype: "",
            fileSizeInKB: "",
            doctitle: "",
            docid: "",
            uploadPercentage: 0,
          },
          fileList: [],
          timer: null,
          uploadTip: "",
          clickBtnType: "",
        };
        // 清空对应区域输入框
        const inputId = area === "ai" ? "txt_SearchText_ai" : "txt_SearchText";
        const inputDom = document.getElementById(inputId);
        if (inputDom) inputDom.value = "";
        // 刷新显示（对应区域）
        updateFileDisplay(area);
        $message.success("删除成功");
        updateBannerHeight();
        // ===== 更新检索区DOM（隐藏DBFieldBox/切换placeholder） =====
        if (area === "search") {
          updateSearchDomByFileState();
        }
        // 聚焦到对应输入框（兼容DOM存在的情况）
        if (inputDom) {
          inputDom.focus(); // 光标聚焦
        }
      } else {
        $message.error("删除失败");
      }
    })
    .catch((error) => {
      $message.error("删除失败");
    });
}


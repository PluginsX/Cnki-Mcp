async function getClientIdIfNeeded(needClientId) {
  if (!needClientId) return; // 不需要 clientId 则直接返回

  // 如果 clientId 已经准备好了，直接返回
  if (GetCookie("Ecp_ClientId")) return;

  // 如果正在获取 clientId，则等待之前的 Promise 完成
  if (clientIdPromise) {
    await clientIdPromise;
    return;
  }

  // 首次获取 clientId，创建 Promise 并缓存
  clientIdPromise = (async () => {
    try {
      await $.ajax({
        url: URL_CONFIG.recsysapi + "/UtilityOpenApi/GenerateClientID",
        type: "GET",
        dataType: "json",
        timeout: 10000,
        crossDomain: true,
        beforeSend: () => console.log("开始获取 clientId..."),
        success: (res) => {
          console.log("clientId 获取成功");
          // 写入cookie;
          setCookie("Ecp_ClientId", res.Data, null, ".cnki.net");
        },
        error: () => console.error("clientId 获取失败"),
      });

      // 等待 cookie 写入完成（最多等待 1 秒）
      // await waitForClientId();
    } catch (err) {
      console.error("获取 clientId 异常:", err);
    }
  })();

  // 等待 clientId 获取完成
  await clientIdPromise;
}

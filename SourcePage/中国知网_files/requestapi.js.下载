    window.uploadState[currentArea].fileList.push(file);

    setAiTextareaRows(2);
    if (beforeUpload(file, currentArea)) {
      // 传递区域参数
      uploadFile(file, currentArea); // 传递区域参数
      // ===== 仅校验通过时，才更新检索区DOM =====
      if (currentArea === "search") {
        updateSearchDomByFileState();
      }
    } else {
      setAiTextareaRows(2);
      window.uploadState[currentArea].clickBtnType = "";
      // 校验失败后清空非法文件列表，避免残留影响后续状态判断
      window.uploadState[currentArea].fileList = [];
    }
  });
}
// 前置校验（文件格式+大小）添加手动校验
function beforeUpload(file, area = "ai") {
  const fileType = file.name
    .substring(file.name.lastIndexOf(".") + 1)
    .toLowerCase();
  const btnType = window.uploadState[area].clickBtnType; // 读取对应区域的按钮类型

  // 1. 按按钮类型校验文件格式
  if (btnType === "file") {
    if (!window.uploadState.config.fileTypeReg.file.test(file.name)) {
      window.uploadState[area].uploadTip =
        "请上传Word、PDF、PPT、TXT格式的文档"; // 对应区域的提示
      showModal(area);
      return false;
    }
  } else if (btnType === "image") {
    if (!window.uploadState.config.fileTypeReg.image.test(file.name)) {
      window.uploadState[area].uploadTip = "请上传JPG、PNG、JPEG格式的图片"; // 对应区域的提示
      showModal(area);
      return false;
    }
  }

  // 2. 校验文件大小（按按钮类型判断）
  const sizeLimit =
    btnType === "file"
      ? window.uploadState.config.fileSizeLimit.file
      : window.uploadState.config.fileSizeLimit.image;
  const sizeTip = btnType === "file" ? "文件" : "图片";
  const sizeMax = btnType === "file" ? "50 MB" : "3 MB";

  if (file.size > sizeLimit) {
    window.uploadState[area].uploadTip =
      `${sizeTip}过大，单个${sizeTip}最大${sizeMax}`; // 对应区域的提示
    showModal(area);
    return false;
  }

  // 3. 设置对应区域的前置状态（核心修改：操作area对应的子状态）
  window.uploadState[area].uploadStatus = "beforeUpload";
  window.uploadState[area].fileParams = {
    mimetype: fileType,
    fileSizeInKB: (file.size / 1024).toFixed(2) + "KB",
    doctitle: file.name,
    uploadPercentage: 0,
  };

  // 初始化进度模拟（传入区域参数）
  initProgressSimulation(file, area);

  // 显示对应区域的上传框（原有逻辑不变）
  if (area === "ai") {
    document.getElementById("uploadFileBox").style.display = "flex";
    setAiTextareaRows(2);
  } else if (area === "search") {
    document.getElementById("searchUploadFileBox").style.display = "flex";
    // ===== 更新检索区DOM（隐藏DBFieldBox/切换placeholder） =====
    updateSearchDomByFileState();
  }
  updateFileDisplay(area); // 传入区域参数
  return true;
}

// 初始化上传进度模拟（兼容区域参数）
function initProgressSimulation(file, area = "ai") {
  // 新增area参数
  // 清除对应区域的原有定时器（不再清除全局定时器）
  if (window.uploadState[area].timer)
    clearInterval(window.uploadState[area].timer);

  // 计算预计上传时间（公共逻辑不变）
  const fileSizeMB = file.size / 1024 / 1024;
  const baseTime = 2;
  const additionalTimePerMB = 2;
  const uploadTime = baseTime + fileSizeMB * additionalTimePerMB;

  // 初始化对应区域的进度
  window.uploadState[area].fileParams.uploadPercentage = 0;
  updateFileDisplay(area);

  // 模拟进度条（每100ms更新，操作对应区域的状态）
  window.uploadState[area].timer = setInterval(() => {
    if (window.uploadState[area].uploadStatus !== "uploaded") {
      // 对应区域的上传状态
      if (window.uploadState[area].fileParams.uploadPercentage < 99) {
        window.uploadState[area].fileParams.uploadPercentage +=
          99 / (uploadTime * 10);
        updateFileDisplay(area);
      } else {
        window.uploadState[area].fileParams.uploadPercentage = 99;
        updateFileDisplay(area);
        clearInterval(window.uploadState[area].timer);
      }
    } else {
      window.uploadState[area].fileParams.uploadPercentage = 100;
      updateFileDisplay(area);
      clearInterval(window.uploadState[area].timer);
    }
  }, 100);
}

// 上传文件（兼容区域参数，存储对应区域的docid）
function uploadFile(file, area = "ai") {
  // 新增area参数
  // 设置对应区域的上传中状态
  window.uploadState[area].uploadStatus = "uploading";
  updateFileDisplay(area);

  // 构建FormData（公共逻辑不变）
  const formData = new FormData();
  formData.append("file", file);

  // 调用上传接口（公共逻辑不变）
  fetch(URL_CONFIG.uploadUrl + "/aipower/upload/custom/file", {
    method: "POST",
    body: formData,
    credentials: "include",
    // signal: AbortSignal.timeout(100000),
    signal: getTimeoutSignal(100000),
  })
    .then((response) => response.json())
    .then((res) => {
      // 清除对应区域的进度定时器
      clearInterval(window.uploadState[area].timer);

      if (res.code === 0 && res.data) {
        // 上传成功：更新对应区域的状态和docid（核心：不覆盖另一区域）
        window.uploadState[area].uploadStatus = "uploaded";
        window.uploadState[area].fileParams.docid = res.data.docid; // 存储到对应区域的fileParams
        window.uploadState[area].fileParams.uploadPercentage = 100;
        updateFileDisplay(area);
        updateBannerHeight();
        // ===== 更新检索区DOM（隐藏DBFieldBox/切换placeholder） =====
        if (area === "search") {
          updateSearchDomByFileState();
        }
      } else if (res.code === 413002) {
        // 存储空间已满：更新对应区域的错误状态
        window.uploadState[area].uploadTip =
          "您的上传存储空间已满(1G) ， 请删除其它文件，重新上传";
        window.uploadState[area].uploadStatus = "uploaderror";
        window.uploadState[area].fileParams.docid = res.data?.docid || "";
        window.uploadState[area].fileParams.uploadPercentage = -1;
        updateFileDisplay(area);
        showModal(area);
        updateBannerHeight();
        // ===== 更新检索区DOM（隐藏DBFieldBox/切换placeholder） =====
        if (area === "search") {
          updateSearchDomByFileState();
        }
      } else {
        // 其他失败情况：更新对应区域的错误状态
        window.uploadState[area].uploadStatus = "uploaderror";
        window.uploadState[area].fileParams.docid = res.data?.docid || "";
        window.uploadState[area].fileParams.uploadPercentage = -1;
        updateFileDisplay(area);
        updateBannerHeight();
        // ===== 更新检索区DOM（隐藏DBFieldBox/切换placeholder） =====
        if (area === "search") {
          updateSearchDomByFileState();
        }
      }
    })
    .catch((error) => {
      // 网络错误等：更新对应区域的错误状态
      clearInterval(window.uploadState[area].timer);
      window.uploadState[area].uploadStatus = "uploaderror";
      window.uploadState[area].fileParams.uploadPercentage = -1;
      window.uploadState[area].uploadTip = "上传失败，请重试";
      updateFileDisplay(area);
      showModal(area);
      updateBannerHeight();
      // ===== 更新检索区DOM（隐藏DBFieldBox/切换placeholder） =====
      if (area === "search") {
        updateSearchDomByFileState();
      }
    });
}

// 更新文件展示区域（核心：根据状态渲染）（兼容区域参数）
function updateFileDisplay(area = "ai") {
  // 新增area参数
  // 根据区域获取对应DOM元素（原有逻辑不变）
  let fileBox, docIcon, fileTitle, progressBox, deleteBtn, txtBoxContainer;
  document.getElementById("docIconAfter")
    ? document.getElementById("docIconAfter").remove()
    : "";
  if (area === "ai") {
    fileBox = document.getElementById("uploadFileBox");
    docIcon = document.getElementById("docTypeIcon");
    fileTitle = document.getElementById("fileTitle");
    progressBox = document.getElementById("progressBox");
    deleteBtn = document.getElementById("deleteFileBtn");
    txtBoxContainer = document.getElementById("txtBoxContainer");
  } else if (area === "search") {
    fileBox = document.getElementById("searchUploadFileBox");
    docIcon = document.getElementById("searchDocTypeIcon");
    fileTitle = document.getElementById("searchFileTitle");
    progressBox = document.getElementById("searchProgressBox");
    deleteBtn = document.getElementById("searchDeleteFileBtn");
    txtBoxContainer = document.getElementById("searchTxtBoxContainer");
  }
  docIcon.style.display = "inline-block";
  // document.getElementById('docIconAfter') ? document.getElementById('docIconAfter').remove() : ''
  if (!fileBox) return; // 兜底：DOM不存在则返回

  // 读取对应区域的状态数据（核心修改：不再读取全局fileParams）
  const areaState = window.uploadState[area];
  const fileParams = areaState.fileParams;
  const fileList = areaState.fileList;

  // 基础信息渲染（原有逻辑不变，仅使用对应区域的数据）
  fileTitle.textContent = fileParams.doctitle;
  fileTitle.title = fileParams.doctitle;

  // 图标渲染（原有逻辑不变，使用对应区域的数据）
  const isImage = window.uploadState.config.fileTypeReg.image.test(
    fileParams.doctitle,
  );
  if (isImage) {
    const reader = new FileReader();
    reader.onload = function (e) {
      docIcon.src = e.target.result;
    };
    reader.readAsDataURL(fileList[0]); // 对应区域的文件列表
  } else {
    const docType = handleDocType(fileParams.mimetype);
    const iconSuffix = fileParams.uploadPercentage === 100 ? "" : "-gray";
    // docIcon.src = `./nimages/images/upload-${docType}${iconSuffix}-icon.png`;
    if (!document.getElementById("docIconAfter")) {
      let _div = document.createElement("div");
      _div.setAttribute("class", `upload-icons upload-${docType}${iconSuffix}`);
      _div.setAttribute("id", `docIconAfter`);
      docIcon.after(_div);
      docIcon.style.display = "none";
    }
  }

  // 进度/状态渲染（原有逻辑不变，使用对应区域的数据）
  let progressHtml = "";
  const percentage = fileParams.uploadPercentage;
  if (percentage > 0 && percentage < 100) {
    progressHtml = `<span>上传中${Math.min(
      Math.floor(percentage),
      99,
    )}%</span>`;
    deleteBtn.style.display = "none";
    txtBoxContainer.style.display = "none";
    fileBox.classList.remove("uploaded-file");
    fileBox.classList.remove("uploaded-failed");
    fileBox.onmouseenter = null;
    fileBox.onmouseleave = null;
  } else if (percentage === -1) {
    progressHtml = `
    <span class="error">上传失败</span>
    <span class="retry retry-upload" data-area="${area}">重试</span> <!-- 新增data-area标记区域 -->
  `;
    deleteBtn.style.display = "none";
    txtBoxContainer.style.display = "none";
    fileBox.classList.remove("uploaded-file");
    fileBox.classList.add("uploaded-failed");
    fileBox.onmouseenter = null;
    fileBox.onmouseleave = null;
  } else if (percentage === 100) {
    progressHtml = `
      <span class="type">${
        isImage ? fileParams.mimetype : handleDocType(fileParams.mimetype)
      }</span>
      <span>${fileParams.fileSizeInKB}</span>
    `;
    deleteBtn.style.display = "none";
    fileBox.classList.add("uploaded-file");
    fileBox.classList.remove("uploaded-failed");

    /// 上传成功后渲染示例按钮（原有逻辑不变）
    if (window.uploadState.showExample) {
      txtBoxContainer.style.display = "flex";
      txtBoxContainer.innerHTML = "";
      const targetExampleData = isImage ? exampleImageData : exampleData;
      targetExampleData.forEach((item) => {
        const btn = document.createElement("div");
        btn.className = "example-btn-item";
        btn.dataset.docid = item.id;
        btn.dataset.area = area; // 新增data-area标记区域，用于跳转
        btn.innerHTML = `
      <span>${item.txt}</span>
      <span class="arrow-icon"></span>
    `;
        btn.addEventListener("click", function () {
          const baseUrl = "https://ai.cnki.net/trans";
          const allParamsStr = buildAIJumpParams(this.dataset.area); // 传入区域参数
          const urlParams = new URLSearchParams(allParamsStr);
          urlParams.set("question", item.txt);
          const fullUrl = `${baseUrl}?${urlParams.toString()}`;
          console.log("fullUrl", fullUrl);
          window.open(fullUrl, "_blank");
        });
        txtBoxContainer.appendChild(btn);
      });
    } else {
      txtBoxContainer.style.display = "none";
    }
    fileBox.onmouseenter = function () {
      if (percentage === 100) {
        deleteBtn.style.display = "block";
      }
    };
    fileBox.onmouseleave = function () {
      deleteBtn.style.display = "none";
    };
  }
  progressBox.innerHTML = progressHtml;
}


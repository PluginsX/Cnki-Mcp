// 节流
function throttleDebounce(fn, delay, mustRunDelay) {
  var timer = null;
  var t_start;
  return function () {
    var context = this;
    var args = arguments;
    var t_curr = +new Date();

    clearTimeout(timer);
    if (!t_start) {
      t_start = t_curr;
    }
    if (mustRunDelay != 0 && t_curr - t_start >= mustRunDelay) {
      fn.apply(context, args);
      t_start = t_curr;
    } else {
      timer = setTimeout(function () {
        fn.apply(context, args);
      }, delay);
    }
  };
}

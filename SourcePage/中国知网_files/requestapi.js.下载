function updateSearchDomByFileState() {
  const hasFile = isSearchHasFile();
  const dbFieldBox = document.getElementById("DBFieldBox");
  const searchTextarea = document.getElementById("txt_SearchText");
  const searchBtn = document.querySelector(".search-form .search-btn");
  const auxBtnGroup = document.querySelector(".search-aux-btn-group");

  // 1. 隐藏/显示 DBFieldBox
  if (dbFieldBox) {
    dbFieldBox.style.display = hasFile ? "none" : "block";
  }

  // 2. 切换输入框 placeholder 文案
  if (searchTextarea) {
    const defaultPlaceholder = "中文文献、外文文献";
    const fileExistPlaceholder = "请提出您的问题";
    searchTextarea.placeholder = hasFile
      ? fileExistPlaceholder
      : defaultPlaceholder;
  }
  // 3. 新增/移除专属类名
  if (searchBtn) {
    if (hasFile) {
      // 有合法文件：添加专属类名，启用AI风格样式
      searchBtn.classList.add("search-btn-has-file");

// 初始化录音实例
function initProjectRecorder() {
  // ========== 优化：如果已有实例，先销毁再重建 ==========
  if (state.recorder) {
    try {
      state.recorder.recStop();
    } catch (err) {}
    state.recorder = null;
  }
  // 重新创建实例
  state.recorder = jsRecorder((blob, encTime) => {
    if (state.websocket && state.websocket.readyState === WebSocket.OPEN) {
      try {
        state.websocket.send(blob);
      } catch (err) {
        console.error("音频数据发送失败：", err);
        showError("语音数据发送失败，请重试");
        stopRecording();
      }
    }
  });
}

// 开始录音（新增：接收当前点击的按钮DOM）
function startRecording(btnEl) {
  if (state.isRecording || state.isStarting) return;
  state.isStarting = true; // 标记“正在启动录音”，防止重复点击

  // 记录当前点击的按钮（用于更新图标）
  state.currentVoiceBtn = btnEl;
  // 优先使用当前按钮所属区域的输入框
  // const targetInput = btnEl.closest(".search-form-ai")
  //   ? dom.searchInputAI
  //   : dom.searchInput;
  const targetInput = btnEl.closest(".search-form-ai")
    ? document.getElementById("txt_SearchText_ai")
    : document.getElementById("txt_SearchText");
  state.text = targetInput ? targetInput.value || "" : "";

  // 第一步：检测麦克风支持
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    showError("当前浏览器不支持麦克风访问，请升级浏览器");
    state.isStarting = false; // 解锁
    return;
  }

  // 第二步：获取麦克风权限
  navigator.mediaDevices
    .getUserMedia({ audio: true })
    .then((stream) => {
      // 新增：保存媒体流到state
      state.mediaStream = stream;
      // 权限正常：标记状态+更新当前按钮图标
      state.isRecording = true;
      updateVoiceBtnState(btnEl);

      // 连接WebSocket并启动录音
      asrWebSocket();
      initProjectRecorder();
      state.recorder.recStart();
      state.isStarting = false; // 解锁
    })
    .catch((err) => {
      // 麦克风错误：仅提示，不修改状态/图标
      let errorMsg = "无法启动录音：";
      if (err.name === "NotAllowedError") {
        errorMsg += "您拒绝了麦克风权限，请在浏览器设置中开启";
      } else if (err.name === "NotFoundError") {
        errorMsg += "无可用麦克风，请插入麦克风后重试";
      } else {
        errorMsg += err.message || "麦克风访问失败";
      }
      showError(errorMsg);
      // 清理无效连接
      if (state.websocket) {
        state.websocket.close();
        state.websocket = null;
      }
      state.isStarting = false; // 解锁
    });
}

// 停止录音（原有逻辑+更新图标）
function stopRecording() {
  // ========== 新增：强制停止麦克风媒体流 ==========
  if (state.mediaStream) {
    state.mediaStream.getTracks().forEach((track) => {
      track.stop(); // 停止媒体流的所有轨道
    });
    state.mediaStream = null; // 清空引用
  }
  // ========== 强制停止录音实例（兼容重复创建的情况） ==========
  if (state.recorder) {
    try {
      state.recorder.recStop(); // 停止录音
    } catch (err) {
      console.error("强制停止录音失败：", err);
    }
    state.recorder = null; // 清空实例，强制释放
  }

  // 发送结束标记
  if (state.websocket && state.websocket.readyState === WebSocket.OPEN) {
    try {
      state.websocket.send(
        JSON.stringify({
          type: "audio_end",
          is_speaking: false,
          wav_name: "h5",
        }),
      );
    } catch (err) {
      console.error("发送结束标记失败：", err);
    }
    // ========== 强制关闭WebSocket（立即释放连接） ==========
    state.websocket.close(1000, "manual stop"); // 正常关闭
  }
  state.websocket = null; // 清空WebSocket实例
  // 恢复状态+更新当前按钮图标
  state.isRecording = false;
  state.isStarting = false; // 强制解锁
  if (state.currentVoiceBtn) {
    updateVoiceBtnState(state.currentVoiceBtn);
  }
  state.currentVoiceBtn = null;
}

// WebSocket连接（原有逻辑不变）
function asrWebSocket() {
  if (!window.WebSocket) {
    showError("当前浏览器不支持语音输入，请升级浏览器");
    return;
  }

  if (state.websocket) return;

  const wsUrl = URL_CONFIG.wsUrl;
  state.websocket = new WebSocket(wsUrl);

  state.websocket.onopen = () => {
    console.log("WebSocket 连接成功");
    state.websocket.send(
      JSON.stringify({
        chunk_size: [5, 10, 5],
        wav_name: "h5",
        is_speaking: true,
        chunk_interval: 10,
        mode: "2pass",
      }),
    );
  };

  let inputUpdateTimer = null;
  state.websocket.onmessage = (evt) => {
    try {
      const res = JSON.parse(evt.data);
      let newText = "";
      // 判断stamp_sents存在且长度>0 → 取同级的text
      if (res.stamp_sents && res.stamp_sents.length > 0) {
        newText = res.text || ""; // 取和stamp_sents同级的text
      }
      // ======================================

      if (newText) {
        // 只有newText有值时才更新
        state.text += newText;
        if (state.text.length > 100) {
          state.text = state.text.slice(0, 100);
          stopRecording();
          showError("输入内容已达最大长度");
        }
        // 更新对应区域的输入框（原有逻辑不变）
        clearTimeout(inputUpdateTimer);
        inputUpdateTimer = setTimeout(() => {
          // const targetInput = state.currentVoiceBtn.closest(".search-form-ai")
          //   ? dom.searchInputAI
          //   : dom.searchInput;
          const targetInput = state.currentVoiceBtn.closest(".search-form-ai")
            ? document.getElementById("txt_SearchText_ai")
            : document.getElementById("txt_SearchText");
          if (targetInput) {
            targetInput.value = state.text;
            targetInput.dispatchEvent(new Event("input", { bubbles: true }));
          }
        }, 100);
      }
    } catch (err) {
      console.error("解析识别结果失败：", err, "原始数据：", evt.data);
    }
  };

  state.websocket.onerror = (error) => {
    console.error("WebSocket错误：", error);
    showError("语音识别服务连接异常，请检查网络");
    stopRecording();
  };

  state.websocket.onclose = (event) => {
    console.log("WebSocket关闭：", event.code, event.reason);
    if (state.isRecording) {
      state.isRecording = false;
      if (state.currentVoiceBtn) {
        updateVoiceBtnState(state.currentVoiceBtn);
      }
      state.currentVoiceBtn = null;
    }
  };
}


// ============ 公共 AJAX 封装 ============
async function requestApi(url, options = {}) {
  const {
    containerId, // 渲染目标容器 ID（如 "#new-list"）
    transformData, // 数据转换函数（入参：data.data → 返回 normalized array）
    renderItem, // 渲染单项的函数（入参：item, index → 返回 HTML 字符串 或 jQuery 对象）
    isUseNormalizeArticle = true, // 是否默认使用 normalizeArticle 转换
    onSuccess, // 可选：自定义成功后逻辑（如额外统计）
    onError, // 可选：自定义错误处理
    personContainerId, // 表头父级节点id
    fallbackData, //兜底数据
  } = options;
  // 检查是否需要 clientId 并提前获取
  await getClientIdIfNeeded(options.needClientId);
  var transformed = [];

  return $.ajax({
    url,
    type: "GET",
    dataType: "json",
    timeout: 10000,
    xhrFields: { withCredentials: true },
    crossDomain: true,
    beforeSend: function () {
      // console.log("🔄 请求发送中...", url);
    },
    success: function (data, textStatus, jqXHR) {
      // console.log("✅ 请求成功:", url, data);
      let editorNew = document.getElementById("editor-new");
      let editoHot = document.getElementById("editor-hot");
      try {
        if (
          data.code === 0 &&
          Array.isArray(data.data) &&
          data.data.length > 0
        ) {
          // 判断是否需要使用转换函数
          var normalized = isUseNormalizeArticle
            ? data.data.map(normalizeArticle)
            : data.data; // 是否使用公共转换函数
          transformed =
            typeof transformData === "function"
              ? transformData(normalized).slice(0, 25)
              : normalized.slice(0, 25);
          if (typeof onSuccess === "function") onSuccess(transformed);
          // 处理专题模块是否展示1
          if (options.renderItem.name === "renderSpecialTopicItem") {
            $("#editor-theme").show();
            editorNew.style.width = "510px";
            editoHot.style.width = "510px";
          }
        } else {
          // 处理专题模块是否展示2
          if (options.renderItem.name === "renderSpecialTopicItem") {
            $("#editor-theme").hide();
            editorNew.style.width = "49.5%";
            editoHot.style.width = "49.5%";
          }
          // 数据返回为空的时候兜底数据使用
          if (
            Array.isArray(transformed) &&
            transformed.length === 0 &&
            fallbackData
          ) {
            transformed = JSON.parse(JSON.stringify(fallbackData));
            if (options.renderItem.name === "renderTrackItem") {
              trackData = transformed;
            }
          }
          console.warn(options.renderItem.name, "请求成功但无有效数据", data);
        }

        dealMethods(options, transformed);
      } catch (err) {
        console.error("❌ 渲染过程异常", err);
      }
    },
    error: function (jqXHR, textStatus, errorThrown) {
      if (
        Array.isArray(transformed) &&
        transformed.length === 0 &&
        fallbackData
      ) {
        transformed = JSON.parse(JSON.stringify(fallbackData));
        if (options.renderItem.name === "renderTrackItem") {
          trackData = transformed;
        }
      }
      dealMethods(options, transformed);
      const msg =
        textStatus === "timeout" ? "请求超时" : `${textStatus}: ${errorThrown}`;
      console.error(`❌ 请求失败 [${url}]`, msg, "状态码:", jqXHR.status);
      if (typeof onError === "function")
        onError(jqXHR, textStatus, errorThrown);
    },
    complete: function (jqXHR, textStatus) {
      // console.log("🔚 请求结束:", url);
    },
  });
}


// === 新增公共辅助函数：根据区域和文件类型获取默认检索词 ===
window.getUploadDefaultQuestion = function (area = "ai") {
  const areaState = window.uploadState[area];
  // 1. 校验是否有上传成功的文件/图片
  if (
    !areaState ||
    areaState.uploadStatus !== "uploaded" ||
    areaState.fileList.length === 0
  ) {
    return ""; // 无上传文件，返回空
  }
  const fileTitle = areaState.fileParams.doctitle;
  const config = window.uploadState.config;
  // 2. 判断是文件还是图片，返回对应默认文案
  if (config.fileTypeReg.image.test(fileTitle)) {
    return "请对图片内容进行解释分析"; // 图片默认文案
  } else {
    return "总结文档核心内容"; // 文档默认文案
  }
};

// === 新增公共辅助函数：判断对应区域是否处于文件上传中 ===
window.isFileUploading = function (area = "ai") {
  const areaState = window.uploadState[area] || {
    fileParams: { uploadPercentage: 0 },
  };
  const uploadPercentage = areaState.fileParams.uploadPercentage || 0;
  // 上传中状态：进度大于0且小于100（未上传完成）
  return uploadPercentage > 0 && uploadPercentage < 100;
};

// === 判断指定区域是否上传失败（状态为uploaderror） ===
window.isFileUploadFailed = function (area = "ai") {
  const areaState = window.uploadState[area] || { uploadStatus: "notUpload" };
  return areaState.uploadStatus === "uploaderror";
};

// === 新增：判断检索区是否有文件（无论上传状态：中/成功/失败） ===
function isSearchHasFile() {
  const searchState = window.uploadState?.search || { fileList: [] };
  // 只要fileList非空，就认为有文件（无论上传状态）
  return Array.isArray(searchState.fileList) && searchState.fileList.length > 0;
}


// 处理echarts词云使用数据（手动设置value大小）
function mapToNameValue(list, min = 1, max = 100) {
  const colorsMap = [
    { fontColor: "#2C68F5", hoverColor: "#2352C2" },
    { fontColor: "#D28100", hoverColor: "#9E6200" },
    { fontColor: "#24A05B", hoverColor: "#196E3E" },
    { fontColor: "#D9461D", hoverColor: "#A63516" },
  ];
  if (!Array.isArray(list) || list.length === 0) {
    return [];
  }
  // const items = list.map((entry) => entry.item);
  const items = list;
  const n = items.length;
  const colorCount = colorsMap.length;

  if (n === 1) {
    const { fontColor, hoverColor } = colorsMap[0] || {};
    return [{ name: items[0], value: max, fontColor, hoverColor }];
  }

  const step = (max - min) / (n - 1);
  return items.map((name, index) => {
    const value = max - step * index;
    const colorEntry = colorsMap[index % colorCount] || {};
    return {
      name,
      value: parseInt(value.toFixed(2)),
      fontColor: colorEntry.fontColor,
      hoverColor: colorEntry.hoverColor,
    };
  });
}


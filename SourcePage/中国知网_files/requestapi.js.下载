// === 过滤特殊字符函数 ===
function strFilter(s) {
  if (!s) return "";
  var pattern = new RegExp(/[\\<>]/); // 不允许输入 \ < > 等字符
  var rs = "";
  for (var i = 0; i < s.length; i++) {
    rs = rs + s.substr(i, 1).replace(pattern, "");
  }
  return rs.trim();
}


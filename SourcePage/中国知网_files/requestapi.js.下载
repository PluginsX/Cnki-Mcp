// 存储当前选中的值（用于高亮）
let currentSelectedValue = "知网文献"; // 默认选中“知网文献”

document.addEventListener("DOMContentLoaded", function () {
  if (dropdownBtn) {
    dropdownBtn.addEventListener("click", function (e) {
      e.stopPropagation();
      const isHidden =
        dropdownMenu.style.display === "none" || !dropdownMenu.style.display;

      document.querySelectorAll(".dropdown-menu").forEach((menu) => {
        if (menu !== dropdownMenu) menu.style.display = "none";
      });

      dropdownMenu.style.display = isHidden ? "block" : "none";
      this.classList.toggle("open", isHidden);
    });
  }

  if (dropdownMenu) {
    dropdownMenu.querySelectorAll("li").forEach((item) => {
      item.addEventListener("click", function () {
        const value = this.dataset.value;
        const iconClass = this.dataset.icon;

        if (value === "全库问答") {
          const iconEl = dropdownBtn.querySelector(".icon");
          const textEl = dropdownBtn.querySelector("span:last-child");
          iconEl.className = "icon icon_folder";
          textEl.textContent = "知网文献";
        } else {
          const iconEl = dropdownBtn.querySelector(".icon");
          const textEl = dropdownBtn.querySelector("span:last-child");
          iconEl.className = "icon " + iconClass;
          textEl.textContent = value;
        }

        currentSelectedValue = value;
        dropdownMenu.style.display = "none";
        dropdownBtn.classList.remove("open");

        dropdownMenu
          .querySelectorAll("li")
          .forEach((li) => li.classList.remove("selected"));
        this.classList.add("selected");
      });
    });
  }

  document.addEventListener("click", function (e) {
    if (dropdownBtn && dropdownMenu) {
      if (!dropdownBtn.contains(e.target) && !dropdownMenu.contains(e.target)) {
        dropdownMenu.style.display = "none";
        dropdownBtn.classList.remove("open");
      }
    }
  });
});


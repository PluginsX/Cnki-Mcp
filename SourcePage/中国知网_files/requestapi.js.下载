  }

  // 2. 文字内容（移除关闭按钮）
  const textEl = document.createElement("span");
  textEl.textContent = text;
  messageEl.appendChild(textEl);

  document.body.appendChild(messageEl);

  // 显示提示
  setTimeout(() => messageEl.classList.add("show"), 10);

  // 自动关闭（默认3秒，不可取消）
  setTimeout(() => {

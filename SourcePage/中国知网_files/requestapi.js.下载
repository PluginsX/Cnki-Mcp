function updateCiyunDisplay() {
  // 获取当前激活的标签类型
  const activeType = $("#ciyunmyModal .tags span.active").data("type");
  if (activeType === "related") {
    if (hasRelatedWords) {
      $(".ciyunimg").show();
      $(".nociyunimg").hide();
      $("#relatedwords").show();
      $("#similarwords").hide();
    } else {
      $(".ciyunimg").hide();
      $(".nociyunimg").show();
    }
  } else if (activeType === "similar") {
    if (hasSimilarWords) {
      $(".ciyunimg").show();
      $(".nociyunimg").hide();
      $("#similarwords").show();
      $("#relatedwords").hide();
    } else {
      $(".ciyunimg").hide();
      $(".nociyunimg").show();
    }
  }
}


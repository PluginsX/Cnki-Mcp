  $(clickedSpan).addClass("active");

  if (hasSimilarWords) {
    $(".ciyunimg").show();
    $(".nociyunimg").hide();
    $("#similarwords").show();
    $("#relatedwords").hide();
  } else {
    $(".ciyunimg").hide();
    $(".nociyunimg").show();

    if (wordCloudChart) {
      wordCloudChart.clear();
      $("#similarwords").hide();
    }
    return;
  }
  const container = document.getElementById("similarwords");
  if (!wordCloudChart) {
    wordCloudChart = echarts.init(container);
    wordCloudChart.on("click", function (params) {
      const keyword = params.name;
      const url = `https://kns.cnki.net/kns8s/defaultresult/index?korder=SU&kw=${encodeURIComponent(
        keyword,
      )}`;
      window.open(url, "_blank");
    });
  }
  wordCloudChart.setOption(getWordCloudOption(similarWordsArr), true);
};

// 点击相关文献逻辑 1、判断当前展示的是相似词or相关词 2、确定关键词拼接 a + b + c 3、跳转
window.jump2CNKI = function (clickedBtn) {
  var keywords = "";
  const activeTag = document.querySelector(".tags span.active");
  const type = activeTag ? activeTag.dataset.type : null;
  if (type === "related") {
    console.log("// 相关词高亮", relatedWordsArr);
    keywords = relatedWordsArr.join(" + ");
  } else if (type === "similar") {
    console.log("// 相似词高亮", similarWordsArr);
    let tempArr = similarWordsArr.map((item) => {
      return item.name;
    });
    keywords = tempArr.join(" + ");
  }
  console.log(keywords);
  const url = `https://kns.cnki.net/kns8s/defaultresult/index?korder=SU&kw=${encodeURIComponent(
    keywords,
  )}`;
  window.open(url, "_blank");
};

// 词云弹框展示

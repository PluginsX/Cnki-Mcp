    } else {
      // 无文件：移除专属类名，还原默认样式
      searchBtn.classList.remove("search-btn-has-file");
      // 还原按钮属性
      searchBtn.removeAttribute("title");
      searchBtn.style.color = "#fff"; // 显示原有value文字
    }
  }
  // 4. 切换辅助按钮父容器类名（整体调整位置）
  if (auxBtnGroup) {
    if (hasFile) {
      auxBtnGroup.classList.add("btn-group-has-file");
    } else {
      auxBtnGroup.classList.remove("btn-group-has-file");
    }
  }
}


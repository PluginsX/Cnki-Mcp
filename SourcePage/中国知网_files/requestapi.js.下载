// 公共处理数据的方法原dataPublicDeal.js
const isArray = (data) => {
  if (!Array.isArray) {
    Array.isArray = function (data) {
      return Object.prototype.toString.call(data) === "[object Array]";
    };
  } else {
    return Array.isArray(data);
  }
};

// 作者 机构 基金    数据处理
const dealCommonData = function (data) {
  if (!data) {
    return;
  }
  let arr = [];
  data.forEach((item) => {
    let obj = {};
    Object.keys(item).forEach((k) => {
      obj[k] = item[k];
    });
    if (!!item.relations && item.relations.length > 0) {
      item.relations.forEach((_item) => {
        obj[_item.scope + "Url"] = _item.url;
      });
    }
    if (!!item.metrics && item.metrics.length > 0) {
      item.metrics.forEach((ele) => {
        obj[ele.name] = ele.value;
      });
    }
    if (obj.PUC) {
      obj.MERICTW = obj.PUC;
    }
    arr.push(obj);
  });
  return arr;
};

const getDataPublicDeal = function (
  metadata,
  relations,
  source,
  authors,
  affiliations,
  keywords,
  funds,
  metrics,
  related,
  issues,
  publishing,
  repository,
) {
  let obj = {};
  // 统计数据  作者知网节中处理 metrics issues 也一样
  if (!!metadata && metadata.length > 0) {
    metadata.forEach((ele) => {
      obj[ele.name] = ele.value;
    });
  }
  // 所有url
  if (!!relations && relations.length > 0) {
    relations.forEach((ele) => {
      obj[ele.scope + "Url"] = ele.url;
    });
  }
  //统计数据  作者知网节中处理 metrics issues
  if (!!metrics && metrics.length > 0) {
    metrics.forEach((ele) => {
      obj[ele.name] = ele.value;
    });
  }
  //出版物年期
  if (!!issues && issues.length > 0) {
    issues.forEach((ele) => {
      obj[ele.name] = ele.value;
    });
  }
  //处理出版物的信息  source在攻读期成果返回的数据是数组  在其他地方返回的是对象 2022.4.12
  if (!!source && (Object.keys(source).length > 0 || source.length > 0)) {
    let newSource = isArray(source) ? source[0] : source; // 依赖 isArray
    obj.SOURCE = newSource;
    if (!!newSource.relations && newSource.relations.length > 0) {
      newSource.relations.forEach((ele) => {
        obj.SOURCE[ele.scope + "Url"] = ele.url;
      });
    }
  }
  // 作者
  if (!!authors && authors.length > 0) {
    obj.AUTHORS = dealCommonData(authors); // 依赖 dealCommonData
    // 为作者添加控制展开收起的属性
    obj.IsShowMore = false;
  }
  // 机构
  if (!!affiliations && affiliations.length > 0) {
    obj.AFFILATIONS = dealCommonData(affiliations); // 依赖 dealCommonData
  }
  // 关键词
  if (!!keywords && keywords.length > 0) {
    obj.KEYWORDS = [];
    keywords.forEach((e) => {
      let keyArr = [];
      let keyObj = {};
      keyObj.type = e.type;
      e.items.forEach((item) => {
        let objKW = {};
        objKW.title = item.item;
        if (!!item.relations && item.relations.length > 0) {
          item.relations.forEach((_item) => {
            if (_item.scope === "ABSTRACT") {
              objKW.url = _item.url;
            }
          });
        }
        keyArr.push(objKW);
      });
      keyObj.items = keyArr;
      obj.KEYWORDS.push(keyObj);
    });
  }
  // 基金
  if (!!funds && funds.length > 0) {
    obj.FUNDS = dealCommonData(funds); // 依赖 dealCommonData
  }
  // 图片来源
  if (!!related && related.relations.length > 0) {
    obj.relatedAbstract = related.relations[0].url;
  }
  //
  if (!!publishing && publishing.length > 0) {
    obj.PUBLISHING = publishing;
  }
  //处理 repository 的信息  目前看返回的是对象，不知是否会返回数组？两种情况都兼容处理下
  if (
    !!repository &&
    (Object.keys(repository).length > 0 || repository.length > 0)
  ) {
    let newRepository = isArray(repository) ? repository[0] : repository; // 依赖 isArray
    obj.REPOSITORY = newRepository;
  }
  return obj;
};

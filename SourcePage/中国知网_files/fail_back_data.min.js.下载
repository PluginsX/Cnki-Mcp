温差约50℃）、应力集中区域（窗口处最大应力达89.1MPa）以及弹性变形规律（最大变形0.83mm）。研究表明，提高热流密度会显著加剧温度、应力和变形，但因材料屈服强度高，未发生不可逆塑性变形。该模型为航空航天等领域大型薄壁构件的喷涂工艺优化、变形预测与尺寸稳定性控制提供了可靠的数字化工具，建议重点关注第2节中对温度‑应力‑变形耦合规律的量化分析。",RECID:"R4P1A1091EBB959130"}];var zrkxlist=[{AUTHORS:[{no:1,id:"000063024323",title:"刘静瑞",aff:[1],email:"",corresponding:!1,relations:[{scope:"ABSTRACT",url:"https://kns.cnki.net/kcms2/author/detail?v=MXvIvFkaDQwp1U4mR9yF2iku42OusDsFgWsw9S5qiNP7hJnzubURLg7e2TODCDxtOT4aRkcljB__bJD-2-_RjL9osKy6xhmFYSTk7ESuBdgWGxQzXJ3gPjHuiqY4ytrY&uniplatform=NZKPT&language=CHS"}],ABSTRACTUrl:"https://kns.cnki.net/kcms2/author/detail?v=MXvIvFkaDQwp1U4mR9yF2iku42OusDsFgWsw9S5qiNP7hJnzubURLg7e2TODCDxtOT4aRkcljB__bJD-2-_RjL9osKy6xhmFYSTk7ESuBdgWGxQzXJ3gPjHuiqY4ytrY&uniplatform=NZKPT&language=CHS"}],ABSTRACTUrl:"https://kns.cnki.net/kcms2/article/abstract?v=MXvIvFkaDQwDEiZWoL-fqXkhHKTBWzVk-FzNpWzc1nPIHH55thSdPaqGf6lq1X4Lk6jtebfqC6Z4F3mce9AlhF65S9LEhrI8-4-A0NYlECXSk7sGBFMpCRv6Nm9HcYlK1c3Q-jCGjmn4up6G5aPCUjqpn7006i1OVkGLYS4u8WHiTb_v1fHW4w==&uniplatform=NZKPT&language=CHS",PT:"2026-02-03 17:44",TI:"血清8b型禽腺病毒Fiber knob蛋白的原核表达与单克隆抗体的制备"},{AUTHORS:[{no:1,id:"000056861825",title:"丁嗣辉",aff:[1],email:"",corresponding:!1,relations:[{scope:"ABSTRACT",url:"https://kns.cnki.net/kcms2/author/detail?v=MXvIvFkaDQwDEiZWoL-fqXKmVcwLakeOm2WJ7IFMIsav9PWO-Oh2aMp5g-SVs0dX7nacEtQ5djTTbXJo-1DD0OHEHpE4nvIsMMQuQFMpw9bPHPdcFlE7VWfxHpc_RFpE&uniplatform=NZKPT&language=CHS"}],ABSTRACTUrl:"https://kns.cnki.net/kcms2/author/detail?v=MXvIvFkaDQwDEiZWoL-fqXKmVcwLakeOm2WJ7IFMIsav9PWO-Oh2aMp5g-SVs0dX7nacEtQ5djTTbXJo-1DD0OHEHpE4nvIsMMQuQFMpw9bPHPdcFlE7VWfxHpc_RFpE&uniplatform=NZKPT&language=CHS"}],ABSTRACTUrl:"https://kns.cnki.net/kcms2/article/abstract?v=MXvIvFkaDQwDEiZWoL-fqXkhHKTBWzVk-FzNpWzc1nPkgLTJP9hiJIaX2JwwDDq4UyA7YMbzhS6CGWwzGNwRD4P6Jq7Fbh5HJLGjd3EhmyO_yP--mHGMhrEzn6G02y7pYDwzv6TiUGcyLuNRcSv4s1EqMMJHLyiqz-SvB-J-f6i6TcKi-qIGZA==&uniplatform=NZKPT&language=CHS",PT:"2026-02-03 17:44",TI:"星座雷达天线用新型透波纳米热控薄膜的设计和应用验证"},{AUTHORS:[{no:1,id:"00007395161
  //   showPersonalLoginFlag = true
  // }
  isPersonalOrUnitSlide = 0;
  $(".ecp_loginErrMsg").text("");
  //   $(".ecp_passWord").val("");
  //e.stopPropagation();
  if (!showPersonalLoginFlag) {
    if (
      (Ecp_LoginUsers == 2 || Ecp_LoginUsers == 3) &&
      cookie("Ecp_LoginStuts")
    ) {

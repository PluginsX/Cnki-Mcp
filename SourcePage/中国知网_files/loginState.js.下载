// 个人登录
function ECP_PersonalLogin() {
  $(".ecp_loginErrMsg").hide();
  // $(".ecp-phone-tip").hdie();
  $(".ecp_userNameBox").removeClass("ecp-input-error-tip")
  $(".ecp_passwordBox").removeClass("ecp-input-error-tip")
  ecpLoginType = 2;
  $(".ecp-error-text").hide();
  username = $.trim($(".ecp_userName").val());
  pwd = aes256Encrypt($.trim($(".ecp_passWord").val()));
  isAutoLogin = $(".ecp_checkedutoLogin").is(":checked");
  if (!username) {
    $(".ecp_userNameBox").addClass("ecp-input-error-tip");
    $(".ecp-account-error").show();
    $(".account-error-text").text("请输入用户名");
  } else if (!$.trim($(".ecp_passWord").val())) {
    $(".ecp-password-error").show();
    $(".ecp_passwordBox").addClass("ecp-input-error-tip");
    $(".password-error-text").text("请输入密码");
  } else if (!$("#agreement").is(":checked")) {
    $("#ecp-agreement-wrap").show();
    window.parentLoginHandle = ECP_PersonalLogin;
    return;
  } else {
    getUserLoginStatus();
    Ecp_UserLogin(username, pwd, isAutoLogin, p, 1);
  }
}

function ECP_PhoneLogin() {
  $(".ecp_phoneBox").removeClass("ecp-input-error-tip")
  $(".ecp_codeBox").removeClass("ecp-input-error-tip")
  $(".ecp_loginErrMsg").hide();
  // $(".ecp-phone-tip").show();
  var regx = /^[1][3-9][0-9]{9}$/;
  $(".ecp-error-text").hide();
  ecpPhone = $.trim($(".ecp_phone").val());
  ecpCode = $.trim($(".ecp_code").val());
  isAutoLogin = $(".ecp_checkedutoLogin").is(":checked");
  if (!ecpPhone) {
    $(".ecp_phoneBox").addClass("ecp-input-error-tip");
    $(".ecp-phone-error").show();
    $(".phone-error-text").text("请输入手机号码");
  } else if (!regx.test(ecpPhone)) {
    $(".ecp_phoneBox").addClass("ecp-input-error-tip");
    $(".ecp-phone-error").show();
    $(".phone-error-text").text("请填写正确的手机号码");
  } else if (!ecpCode) {
    $(".ecp_codeBox").addClass("ecp-input-error-tip");
    $(".ecp-code-error").show();
    $(".code-error-text").text("请输入验证码");
  } else if (!$("#agreementSms").is(":checked")) {
    $("#ecp-agreement-wrap").show();
    window.parentLoginHandle = ECP_PhoneLogin;
    return;
  } else {
    // if(!window.nc_requestId) {
    //   $(".ecp_codeBox").addClass("ecp-input-error-tip");
    //   $(".ecp-code-error").show();
    //   $(".code-error-text").text("请发送验证码");
    //   captcha.show();
    //   return
    // }
    getUserLoginStatus();
    var signUrl =
      Ecp_topLoginUrl1 +
      "api/Register/CreateOrLogin?mobile=" +
      ecpPhone +
      "&phoneCode=" +
      ecpCode +
      "&requestID=" + "" + 
      "&loginType=" +
      p;
    var param = {
      mobile: ecpPhone,
      phoneCode: ecpCode,
      requestID: "",
      loginType: p,
    };
    if (typeof Ecp_platform !== "undefined" && !isNull2(Ecp_platform)) {
      param.platform = Ecp_platform;
      signUrl += "&platform=" + Ecp_platform;
    }
    createSign(signUrl);
    $.ajax({
      url: Ecp_topLoginUrl1 + "api/Register/CreateOrLogin",
      data: JSON.stringify(param),
      type: "POST",
      cache: false,
      xhrFields: {
        withCredentials: true,
      },
      contentType: "application/json",
      success: function (result) {
          Ecp_LoginSuccessOne(p, result, 3, true,true);
      },
      error: function (XMLHttpRequest, textStatus, errorThrown) {},
      complete: function (XMLHttpRequest, textStatus) {
        $("#Ecp_TextBoxPwd").val("");
      },
    });
    // Ecp_UserLogin(ecpPhone, ecpCode, isAutoLogin, p, 1);
  }
}

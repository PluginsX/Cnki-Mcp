function showUnitLogin(e) {
  getUserLoginStatus();
  // 只有点击的情况下才同步状态  刘雨露有个页面直接调用了showUnitLogin方法  导致出现了死循环
  if (e) {
    if (p != 0) {
      var tempShowFlag = showFlag;
      FlushLogin();
      showFlag = tempShowFlag;
    }
  }
  if (
    [2, 3].indexOf(p) == -1 &&
    $(".ecp_header_unit_loginIcon ").hasClass("ecp_unit_loginCss")
  ) {
    $(".ecp_unit_LoginoutBox").hide();
    $(".ecp_header_unit_loginIcon").removeClass("ecp_unit_loginCss");
    $(".ecp_header_unit_loginIcon").hide();
    $(".ecp_header_unitName").hide();
    $(".ecp_header_unit_loginbg").show();
    // $(".ecp_header_unit_loginIcon").attr("title",'')
  }
  if (p == 0) {
    $(".ecp_mycnki_LoginoutBox").hide();
    $("#Ecp_top_logout_layer").hide();
    $(".ecp_header_personalName_loginbg").hide();
    $(".ecp_header_personal_loginbg").css("display", "inline-block");
    $(".ecp_header_personal_loginbg").show();
    $(".ecp_unit_LoginoutBox").hide();
    $(".ecp_header_unit_loginbg").css("display", "inline-block");
    $(".ecp_header_unit_loginbg").show();
    $(".ecp_header_unit_loginIcon").hide();
    $(".ecp_header_unitName").hide();
  }
  isPersonalOrUnitSlide = 1;
  $(".ecp_loginErrMsg").text("");
  //   $(".ecp_unitPassWord").val("");
  //e.stopPropagation();
  if (!showFlag) {
    if (
      (Ecp_LoginUsers == 1 || Ecp_LoginUsers == 3) &&
      cookie("Ecp_LoginStuts")
    ) {
      // 如果个人也登录的情况下  机构下拉名称变成不可点击状态
      var loginStatus = JSON.parse(cookie("Ecp_LoginStuts"));
      if (loginStatus.UserType === "jf") {
        $(".ecp_unitAccountName").css("cursor", "default");
      } else {
        $(".ecp_unitAccountName").css("cursor", "pointer");
      }
      $(".ecp_unit_LoginoutBox").show();
    } else {
      $(".ecp_unit_LoginBox").show();
      $(".ecp_unitName").focus();
    }
    $(".ecp_personalLoginBox").hide();
    $(".ecp_mycnki_LoginoutBox").hide();
    $("#Ecp_top_logout_layer").hide();
    showFlag = true;
    showPersonalLoginFlag = false;
  } else {
    $(".ecp_unit_LoginBox").hide();
    $(".ecp_unit_LoginoutBox").hide();
    $(".ecp_personalLoginBox").hide();
    showFlag = false;
    showPersonalLoginFlag = false;
  }
}

clicktoclose();
function clicktoclose() {
  var ename = ".ecp_unit_LoginBox";
  // start
  var ename2 = ".ecp_personalLoginBox";
  // end
  $(document).on("click", function (e) {
    var conss;
    var cc;
    var isin = false;
    for (var i = 0; i < clickUnCloseLoginNames.length; i++) {
      conss = $(clickUnCloseLoginNames[i]);
      if (conss.length > 0) {
        cc = !conss.is(e.target) && conss.has(e.target).length === 0;
        if (!cc) {
          isin = true;
          break;
        }
      }
    }
    if (!isin) {
      $(ename).hide();
      $(ename2).hide();
      $(".ecp_unit_LoginoutBox").hide();
      $(".ecp_mycnki_LoginoutBox").hide();
      $("#Ecp_top_logout_layer").hide();
      showFlag = false;
      showPersonalLoginFlag = false;
    }
  });
}

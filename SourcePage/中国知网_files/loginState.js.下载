function getUserLoginStatus() {
  if (cookie("Ecp_LoginStuts")) {
    var loginStatus = JSON.parse(cookie("Ecp_LoginStuts"));
    if (loginStatus.UserType === "jf") {
      p = 1;
      if (loginStatus.BUserType === "bk") {
        p = 3;
      }
    } else {
      p = 2;
    }
  } else {
    p = 0;
  }
}


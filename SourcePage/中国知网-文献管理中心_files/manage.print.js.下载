}

function GenerateParam(obj) {
    var select = GetQueryStringByName(window.location.href, "select");
    if (select == 0) {
        $.filenameInit();
    }
    else if (select == 1) {
        $.filenameSelectInit();
    }
    var objOrder = '';//点击的排序对象
    var objSelect = '', selectField = '';//点击的预览对象,以及选择的值
    if (!obj) {
        obj = $(".formatlist li.current a");
    }
    if ($(obj).parent().attr("class") == "order-btns") {
        objOrder = obj;
        obj = $(".formatlist li.current a");
        var tempOrderType = !$(objOrder).attr("OrderType") || $(objOrder).attr("OrderType") == "asc" ? "desc" : "asc";
        $(objOrder).attr("OrderType", tempOrderType).addClass("cur").children().attr("class", "icon icon-" + tempOrderType + "end");
        $(objOrder).siblings().attr("OrderType", "").removeClass("cur").children().attr("class", "icon icon-descend");

    }
    //TODO 和中心网站不一样的地方
    else if ($(obj).text() == message.Preview) {
        objSelect = obj;
        obj = $(".formatlist li.current a");
    }
    $("div.check-labels input:checkbox").each(function (i) {
        if ($(this).prop("checked"))
            selectField = selectField.concat($(this).attr("field"), ",");
    })
    $(".formatlist li").removeClass("current");
    $(obj).parent().addClass("current");
    var filename = select == 1?$.filenameSelectGet():$.filenameGet();
    var displaymode = $(obj).attr("displaymode");
    var orderparam = $(".order-btns a.cur").attr("OrderParam");
    var ordertype = $(".order-btns a.cur").attr("OrderType");
    var param = {
        FileName: filename, DisplayMode: displaymode, OrderParam: orderparam,
        OrderType: ordertype, SelectField: selectField, PageIndex: 1, PageSize: 20,
        language: GetQueryStringByName(window.location.href, "language"),
        uniplatform: GetQueryStringByName(window.location.href, "uniplatform"),
        subject : $.getSubject(),
    };
    var dbname = GetQueryStringByName(window.location.href, "dbname");
    var filename2 = GetQueryStringByName(window.location.href, "filename");
    if (filename2) {
        param["FileName"] = filename2;
    }
    if (dbname) {
        param["DBName"] = dbname;
    }
    return param;
}

//自定义导出的全选和取消 sign true：全选  false：取消全选
function checkAllFields(sign) {
    if (sign) {
        $("div.check-labels input:checkbox").each(function (i) {
            $(this).prop("checked", true);
        })
    }
    else {
        $("div.check-labels label[class!='disableclick']").each(function (i) {
            $(this).find("input").prop("checked", false);
        })
    }
}

function my_CopyText(client) {
    var showMode = $(".formatlist li.current a").attr("displaymode");
    var sText = "";
    if (showMode.toUpperCase() == "MLA" || showMode.toUpperCase() == "APA") {
        $("div#result ul.literature-list li").each(function (i) {
            sText += $(this).text().replace(/\r/g, "").replace(/\n/g, "").replace(/      /g,"").replace(/  /g,"") + "\r\n";
        });
    }
    else if (showMode.toUpperCase() == "NOTEEXPRESS") {
        $("div#result ul.literature-list li").each(function (i) {
            sText += $(this).html().replace(/\s+\{/g, "{").replace("&nbsp;","").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/\r/g, "").replace(/\n/g, "").replace(/<BR>/g, "\r\n").replace(/<br>/g, "\r\n") + "\r\n";
        });
    }
    else if (showMode.toUpperCase() == "NODEFIRST") {
        $("div#result ul.literature-list li").each(function (i) {
            sText += $(this).html().replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/\r/g, "").replace(/\n/g, "").replace(/<BR>/g, "\r\n").replace(/<br>/g, "\r\n") + "\r\n";
        });
    }
    else {
        $("div#result ul.literature-list>li").each(function (i) {
            sText += $(this).html().replace(/\r/g, "").replace(/\n/g, "").replace(/<BR>/g, "\r\n").replace(/<br>/g, "\r\n").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/&nbsp;/g, " ").replace(/      {/g,"{").replace(/      /g,"") + "\r\n";
            if(showMode.toUpperCase() == "GBTREFER"){
                sText=sText.replace(/  /g,"");
            }else if(showMode.toUpperCase() == "REFER"||showMode.toUpperCase() == "NEW"||showMode.toUpperCase() == "NEWDEFINE"){
                sText=sText.replace(/    /g,"");
            }else if(showMode.toUpperCase() == "SELFDEFINE"){
                sText=sText.replace(/   /g,"");
            }
            var regA = /<\/?.+?\/?>/g;
            sText = sText.replace(regA, "");
        });
    }
    return sText;
}


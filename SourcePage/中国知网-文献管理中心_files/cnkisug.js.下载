            //var tinfoArr = this.getSplitDataArray(data);
            ////拼音刊名,刊名,英文刊名,主办单位,刊期1,CBD_403,影响因子,综合影响因子,期刊各库代码,优先出版否
            //return { ID: tinfoArr[0], TN: tinfoArr[1], TT: tinfoArr[2], PicSrc: getPicSRC(this.PicServerHosts.CDFD, "/fengmian/CJFD/small/" + tinfoArr[0] + ".jpg"), HREF: getHref(this.LinkArray.CJFD, tinfoArr[0]), IARR: { ZB: tinfoArr[3], ZQ: tinfoArr[4], CBD: tinfoArr[5], FYZ: tinfoArr[6], ZYZ: tinfoArr[7], TZ: [tinfoArr[8].indexOf("T") >= 0 ? "T" : "", tinfoArr[9] == "1" ? "Y" : ""] } };

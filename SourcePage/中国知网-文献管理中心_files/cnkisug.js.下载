SugExpandTip.prototype.getSplitDataArray = function (data) {
    data = data.indexOf("||") > -1 ? data.substring(0, data.indexOf("||")) : data;
    return data.split("$$");
}

SugExpandTip.prototype.InstanceDataHanler = (function () {
    this.getHref = function (linkFormat, v) {
        if (v && linkFormat) {
            return linkFormat.replace(/\{\d\}/ig, v);
        }
        return "";
    }
    this.getPicSRC = function (server, path) {
        return server + path;
    }
    /**
     *
     * @param data json对象
     * @param attribute1 metadata或者relation
     * @param attribute2 metadata或者relation的name的节点值
     * @returns {*}
     */
    this.findData=function (data,attribute1,attribute2) {
        if(!data||!data["data"]){
            return "";
        }
        var metadata=data["data"]["data"][0]["metadata"];
        var relation=data["data"]["data"][0]["relation"];
        if(attribute1=="metadata"){
            for(var i=0;i<metadata.length;i++){
                if(metadata[i]["name"]==attribute2){
                    return metadata[i]["value"];
                }
            }
        }else  if(attribute1=="relation"){
            for(var i=0;i<relation.length;i++){
                if(relation[i]["scope"]==attribute2){
                    return relation[i]["url"];
                }
            }
        }
        return "";
    }
    return {
        CSYD: function (data) {
            var temp = data;
            var infoArray = temp.split("||");
            if (infoArray && infoArray.length > 0) {
                var getPicSrc = function (id, picServer) {
                    if (id) {
                        var t = id.substring(id.length - 1);
                        return picServer + "/suginfo/CSYD/" + t + "/" + id + ".jpg";
                    }
                    return "";
                };
                var reArray = new Array();
                for (var i = 0; i < infoArray.length; i++) {

                    var tinfoArr = this.getSplitDataArray(infoArray[i]);
                    if (tinfoArr.length == 2) {
                        reArray.push({
                            PICSRC: getPicSrc(tinfoArr[0], this.PicServerHosts.CSYD),
                            HREF: getHref(this.LinkArray.CSYD, tinfoArr[0]),
                            AT: tinfoArr[1]
                        });
                    }
                }
                //"/kns/RedirectPage.aspx?action=indexpage&code=csyd&korder=1&kw=" + encodeURI(this.CurSearchWord)
                return {
                    TN: this.CurSearchWord,
                    TT: "数据",
                    HREF: getHref("http://tongji.cnki.net/kns55/Dig/DigResult.aspx?postZones=xj35%3B&postTar={0}&postYear=ra2000&areaSelType=xjSel&refersource=kdn", encodeURI(this.CurSearchWord)),
                    IARR: reArray
                };
            }
        },
        IMAGE: function (data) {
            //{ TN: "草原", TT: "图片", IARR: [{PICSRC:"",HREF:"",AT:""}, {PICSRC:"",HREF:"",AT:""}] }
            //
            var temp = data;
            var infoArray = temp.split("||");
            if (infoArray && infoArray.length > 0) {
                var reArray = new Array();
                for (var i = 0; i < infoArray.length; i++) {
                    var tinfoArr = this.getSplitDataArray(infoArray[i]);
                    if (tinfoArr.length == 2) {
                        reArray.push({
                            PICSRC: getPicSRC(this.PicServerHosts.IMAGE, "/getimage.ashx?id=" + tinfoArr[0]),
                            HREF: getHref(this.LinkArray.IMAGE, tinfoArr[0]),
                            AT: tinfoArr[1]
                        });
                    }
                }

                return {
                    TN: this.CurSearchWord,
                    TT: "图片",
                    HREF: "//kns.cnki.net/kns/RedirectPage.aspx?action=indexpage&code=IMAGE&korder=1&kw=" + encodeURI(this.CurSearchWord),
                    IARR: reArray
                };
            }
        },
        CJFD: function (data) {
            var dataArray = data.split("||");
            var dataJsonArray = new Array();
            for (var i = 0; i < dataArray.length; i++) {
                var tinfoArr = this.getSplitDataArray(dataArray[i]);
                //拼音刊名,刊名,英文刊名,主办单位,刊期1,CBD_403,影响因子,综合影响因子,期刊各库代码,优先出版否
                dataJsonArray[i] = {
                    ID: tinfoArr[0],
                    TN: tinfoArr[1],
                    TT: tinfoArr[2],
                    PicSrc: getPicSRC(this.PicServerHosts.CJFD, "/CJFD/small/" + tinfoArr[0] + ".jpg"),
                    HREF: getHref(this.LinkArray.CJFD, tinfoArr[0]),
                    IARR: {
                        ZB: tinfoArr[3],
                        ZQ: tinfoArr[4],
                        CBD: tinfoArr[5],
                        FYZ: tinfoArr[6],
                        ZYZ: tinfoArr[7],

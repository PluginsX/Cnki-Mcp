        CYFD: function (data) {
            //拼音刊名,年鉴中文名,年鉴英文名,年鉴年份,ISBN,出版者,出版时间,编号
            //年鉴中文名，年鉴英文名，年鉴年份，ISBN，出版者，出版日期
            ///fengmian/CYFD/N2007080113.jpg
            var tinfoArr = this.getSplitDataArray(data);
            if (tinfoArr.length >= 8) {

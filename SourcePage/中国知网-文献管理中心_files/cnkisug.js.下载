                    LC: tinfoArr[4],
                    SCF: tinfoArr[5],
                    SDF: tinfoArr[6],
                    FW: tinfoArr[7]
                }
            };
        },
        CDFD: function (data) {
            if (typeof data == "string") {//string类型是旧的，sug接口新的data是object对象
                var tinfoArr = this.getSplitDataArray(data);
                return {

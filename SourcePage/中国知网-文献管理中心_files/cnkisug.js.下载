function tipDivOnMouseOverEvent(curObj, isEx, w, kw, ev) {
    var exEvent = function () {
        var curOCN = $(curObj).attr("class")
        if (curOCN.indexOf("drop_selected") >= 0) {
            return true;
        }
        tipClass(curObj, 'drop_selected');
        //        curObj.className = 'drop_selected';
        if (isEx) {
            SugExpand.expendTR(w, kw, curObj, sugPara.Expara || {});
        } else {
            $('#expandarea').hide();
        }
    }
    var e = window.event || ev;
    var s = e.fromElement || e.relatedTarget;
    if (s) {

        if (document.all) {
            if (!(s == curObj || curObj.contains(s))) {
                exEvent();
            }
        } else {
            var res = curObj.compareDocumentPosition(s);
            if (!(s == curObj || res == 20 || res == 0)) {
                exEvent();
            }
        }
    } else {
        exEvent();
    }
}

function tipDivOnMouseOutEvent(curObj, isEx, ev) {
    var e = window.event || ev;
    var s = e.toElement || e.relatedTarget;
    var expandAreaO = document.getElementById("expandarea");
    var exEvent = function () {
        tipClass(curObj, "");
        if (isEx) {
            $('#expandarea').hide();
        }
        return false;
    }
    var isExpandareaIE = function (s) {
        if ((s && s.id == "expandarea") || (expandAreaO && expandAreaO.contains(s))) {
            return true;
        }
        if (!curObj.contains(s)) {
            return exEvent();
        }
        return true;
    }

    var isExpandareaNotIE = function (s) {
        var isContains = function (source, mother) {
            if (mother && source) {
                var res = mother.compareDocumentPosition(source);
                if (!(res == 20 || res == 0)) {
                    return true;
                }
            }
            return false;
        };
        if (!!(curObj && curObj.nodeName && curObj.nodeType == 1) && !!(s && s.nodeName && s.nodeType == 1)) {
            if (!isContains(s, expandAreaO)) {
                return true;
            }
            if (isContains(s, curObj)) {
                return exEvent();
            }
        }
    }

    if (document.all) {
        return isExpandareaIE(s);
    } else {

        return isExpandareaNotIE(s);
    }

}



    //提交检索，返回提示词内容列表
    function searchKeyWord() {
        listIputID = inputid;
        var kw = $("#" + inputid).val().replace(/(^\s*)/g, "");///(^\s*)|(\s*$)/g
        var tDictType = dictType;
        var tIsAttrW = isAttrW;
        if (kw == "") {
            objouter.hide();
            return;
        }
        kw = kw.replace(/\s+/g, " ");
        var sPos = kw.lastIndexOf(" ");
        var preKw = "";
        rawKey = kw;
        if (sPos > 0) {
            preKw = kw.substring(0, sPos + 1);
            if (sPos == kw.length - 1) {
                kw = kw.replace(/(^\s*)|(\s*$)/g, "");
                sPos = kw.lastIndexOf(" ");
                tDictType = "GJGXC";
                tIsAttrW = false;
            }
            kw = kw.substring(sPos + 1, kw.length);
        }

        divPosition();

        selindex = -1;
        tipWordType = 0;
        objouter.empty();
        //加入js 缓存机制 读取格式text|*|attr
        var cachesu = space1.getExData(kw);
        if (cachesu) {
            datahandle(cachesu);
        } else {
            var geturl = sugUrlComm.getURL(sugserver, tDictType, kw, (dbType ? "&dbt=" + dbType : "") + (!tIsAttrW || sPos > 0 ? "" : "&attr=1")); //&jsonvar=oJson
            var CoreDomainClass = new CoreDomainLoadJson();

            CoreDomainClass.Load(geturl, function () {
                var html = "";
                var attr = "";
                if (typeof oJson != "undefined") {
                    if (oJson && Object.prototype.toString.call(oJson) == "[object Array]") {
                        html = oJson.join(";");
                    } else if (oJson.Count != "0") {
                        try {
                            html = oJson.sug;
                            attr = oJson.attr;
                        } catch (e) {
                        }
                    }
                }
                if (html != null && html != ""
                    && $("#" + inputid).val().replace(/(^\s*)|(\s*$)/g, "") != "") {
                    objouter.empty();
                    var tipHtml = HtmlCreater.createlist(html, preKw, getIntutV(), attr);
                    //js缓存机制存入
                    space1.pushSpace(kw, tipHtml);
                    datahandle(tipHtml);
                } else {
                    objouter.hide();
                }
            }, "sugkewword_JS");
        }

        function datahandle(tipHtml) {

            if (tipHtml) {
                objouter.append(tipHtml);
            }

            getDropListItems().mousedown(function (ev) {

                BindTipEvent(this, ev);
            });
            if (document.activeElement.id == inputid)
            //                    objouter.show();
                tipShow();
        }


    }


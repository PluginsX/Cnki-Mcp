            }
        },
        CCND: function (data) {
            //报纸拼音名,CHNAME,主办单位,主管单位,出版地,刊期,国内统一刊号
            //http://192.168.20.170/fengmian/ccnd/JJRB.jpg
            var tinfoArr = this.getSplitDataArray(data);

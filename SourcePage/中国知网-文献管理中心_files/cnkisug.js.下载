        CRFD: function (data) {
            //工具书编号,书名,分辑名,主要责任者,出版者,ISBN,出版日期,封面照片
            //责任者,出版者，ISBN,出版时间
            var temp = data;
            var infoArray = temp.split("||");
            if (infoArray && infoArray.length > 0) {
                var reArray = new Array();
                for (var i = 0; i < infoArray.length; i++) {
                    var tinfoArr = this.getSplitDataArray(infoArray[i]);

function AppendJs(jsurl, callback) {
  var oHead = document.getElementsByTagName("HEAD").item(0);
  var oScript = document.createElement("script");
  oScript.src = jsurl;
  if (callback) {
    oScript.onload = callback;
  }
  oHead.appendChild(oScript);
}

function getMemberInfo(uid) {
  var signUrl = Ecp_topLoginUrl1 + "api/loginapi/get_user_member_info?IdenId=" + uid + "&SourceType=login"
  createSign(signUrl);
  var params = {
    IdenId: uid,
    SourceType: "login"
  }
  $.ajax({
    url: Ecp_topLoginUrl1 + "api/loginapi/get_user_member_info",
    data: JSON.stringify(params),
    type: "POST",
    cache: false,
    headers: {
      authorization: "Bearer" + " " +  + uid
    },
    xhrFields: {
      withCredentials: true,
    },
    contentType: "application/json",
    dataType: "json",
    success: function (result) {
      $(".Ecp_members_operate").hide(); // 广告
      $(".ecp-member-newuser").hide();
      $(".ecp-member-expired").hide();
      $(".ecp-member-valid").hide();
      var data = result.Data;
      switch(data.IsMember) {
        case -1 : 
          $(".Ecp_members_operate").show();
          break;
          // 新用户
        case 0 : 
          $(".ecp-member-newuser").show();
          if(data.CouponEndTime) {
            $(".ecp-member-text").text("立即使用>>");
          } else {
            $(".ecp-member-text").text("立即领取>>");
          }
          $(".member-text-tip").text(data.NoticeMsg)
          break;
        case 1 : 
        // 已过期
        // IsMember等于-2说明超过60天 显示广告
          if(data.IsMember == -2) {
            $(".Ecp_members_operate").show();
          } else {
            $(".ecp-member-expired").show();
            $(".member-text-tip").text(data.NoticeMsg)
          }
          break;
          // 有效期内
        case 3 : 
          $(".ecp-member-valid").show();
          $(".member-text-tip").text(data.NoticeMsg);
          // $(".ecp-member-name").text(data.MemberName)
          // $(".ecp-member-day").text(data.MemberValidityDay + '天')
          // $(".ecp-member-discount").text(data.MemberDiscount + '折')
          break;
        default:
          $(".Ecp_members_operate").show();
      }
        ecpMemberType = data.Member;
        $("#Ecp_top_logout_layer").show();
        $(".ecp_mycnki_LoginoutBox").hide();
    },
  });
}

function AppendCss(path) {
  var a = document.createElement("link");
  a.href = path;
  a.rel = "stylesheet";
  var head = document.getElementsByTagName("head")[0];
  head.appendChild(a);
}


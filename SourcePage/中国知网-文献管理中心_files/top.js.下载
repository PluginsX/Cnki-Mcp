function InitPage3() {
  var style = GetParams("style");
  if (isNull(style)) {
    style = "1";
  }
  Ecp_Style = style;

  var laylocate = GetParams("laylocate");
  if (isNull(laylocate)) {
    Ecp_Lay_Locate = "left";
  } else {
    Ecp_Lay_Locate = laylocate;
  }

  if (Ecp_Style === "1" || Ecp_Style === "3") {
    Ecp_IsLoginRegist = true;
  }
  isWithIpLogin = GetParams("isWithIpLogin");
  if (isNull(isWithIpLogin)) isWithIpLogin = "0";
  var returnUrl = GetParams("returnUrl");
  var isAutoIpLogin = GetParams("isAutoIpLogin") || "1";
  Ecp_platform = GetParams("platform");
  AppendUID = GetParams("AppendUID");

  var showmember = GetParams("showmember") || 1;
  ecp_showmember = isNull(showmember) ? 0 : 1;
  if (isNull(showmember)) {
    ecp_showmember = 0;
  } else {
    var tshowm = parseInt(showmember);
    ecp_showmember = isNull(tshowm) ? 0 : tshowm;
  }

  if (isNull(returnUrl)) {
    returnUrl = "https://www.cnki.net";
  }

  if (!isNull(Ecp_platform)) {
    returnUrl = decodeURIComponent(returnUrl);
    returnUrl = changeUrlArg(returnUrl, "platform", Ecp_platform);
    returnUrl = encodeURIComponent(returnUrl);
  }

  if (!isNull(isAutoIpLogin) && isAutoIpLogin === "1") {
    Ecp_isAuotIpLogin = "1";
  } else {
    Ecp_isAuotIpLogin = "0";
  }

  var modalname = "model1.html";
  if (Ecp_Style === "1") {
    modalname = "model1.html";
  } else if (Ecp_Style === "3") {
    modalname = "model3.html?v=20251216";
  } else {
    modalname = "model2.html";
  }

  var placeid = GetParams("placeid");
  var placesucc = false;
  if (!isNull(placeid)) {
    var placeho = $("#" + placeid + ":first");
    if (placeho) {
      placeho.load(
        Ecp_staticSource + modalname,
        function (responseTxt, statusTxt, xhr) {
          if (statusTxt == "success") {
            AppendJs(
              Ecp_agreementUrl + "/scripts/ecpAgreementAlertLink.js?v=20251216",
              InitPage4
            );
          }
        }
      );
      placesucc = true;
    }
  }
  if (!placesucc) {
    //$("body:first").prepend(result);
    $("body:first").load(
      Ecp_staticSource + modalname,
      function (responseTxt, statusTxt, xhr) {
        if (statusTxt == "success") {
          AppendJs(
            Ecp_agreementUrl + "/scripts/ecpAgreementAlertLink.js?v=20251216",
            InitPage4
          );
        }
      }
    );
  }
}


function ecpSendCode() {
  $(".ecp-phone-error").hide();
  $(".ecp_phoneBox").removeClass("ecp-input-error-tip");
  var ecpPhone = $.trim($(".ecp_phone").val());
  var signUrl =
    Ecp_topLoginUrl1 +
    "api/Register/Send_verify_code?to=" +
    ecpPhone +
    "&isCheck=true";
  var param = {
    to: ecpPhone,
    isCheck: true,
  };

  if (typeof Ecp_platform !== "undefined" && !isNull2(Ecp_platform)) {
    param.platform = Ecp_platform;
    signUrl += "&platform=" + Ecp_platform;
  }
  ResetCheckCode();
  createSign(signUrl);
  $.ajax({
    url: Ecp_topLoginUrl1 + "api/Register/Send_verify_code",
    data: JSON.stringify(param),
    type: "POST",
    cache: false,
    xhrFields: {
      withCredentials: true,
    },
    contentType: "application/json",
    success: function (result) {
      if (result.Code == 1) {
        var count = 60;
        ecpCountdown = setInterval(function () {
          if (count === 0) {
            $(".ecp-text-btn").css("cursor", "pointer");
            $(".ecp-text-btn").text("重新获取");
            clearInterval(ecpCountdown);
          } else {
            $(".ecp-text-btn").css("cursor", "default");
            $(".ecp-text-btn").text(count + "s");
          }
          count--;
        }, 1000);
      } else if (result.Code == -9) {
        $(".ecp_codeBox").addClass("ecp-input-error-tip");
        $(".ecp-code-error").show();
        // $(".code-error-text").text(result.Message);
        $(".code-error-text").html(
          result.Message +
            "<a style='color: #3d6feb;text-decoration: underline;text-underline-offset: 3px;' href='https://my.cnki.net/mycnki/index.html#/?bindPhone=1' target='_balnk'>去认证</a>"
        );
      } else {
        $(".ecp_codeBox").addClass("ecp-input-error-tip");
        $(".ecp-code-error").show();
        $(".code-error-text").text(result.Message);
      }
    },
    error: function (XMLHttpRequest, textStatus, errorThrown) {},
    complete: function (XMLHttpRequest, textStatus) {
      $("#Ecp_TextBoxPwd").val("");
    },
  });
}

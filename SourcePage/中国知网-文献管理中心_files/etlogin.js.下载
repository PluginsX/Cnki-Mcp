      "&isAutoLogin=" +
      b_AutoLogin +
      "&checkCode=" +
      cCode +
      "&p=" +
      p +
      "&verifyType=3";
  } else {
    param = {
      userName: userName,
      pwd: pwd,
      isAutoLogin: isAutoLogin,
      p: p, //vc: Ecp_VerifyCode + "|" + Ecp_VerifyCount,
    };
    signUrl =

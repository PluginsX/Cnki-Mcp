        name=sessionCookieUnit.handlerName(name);
        var cookiename = encodeURIComponent(name) + "=",
            cookiestar = document.cookie.indexOf(cookiename),
            cookievalue = null;
        if (cookiestar > -1) {
            var cookiend = document.cookie.indexOf(";", cookiestar);
            if (cookiend == -1) {
                cookiend = document.cookie.length;
            }
            cookievalue = decodeURIComponent(document.cookie.substring(cookiestar + cookiename.length, cookiend));
        }
        return cookievalue;
    },
    //检索设置需要区分不同平台，默认走NZKPT，其它的需要加平台名称，避免互相影响
    handlerName:function (name){

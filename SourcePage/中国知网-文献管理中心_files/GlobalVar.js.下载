function GetQueryStringByName(query, name) {
    if (!!query == false || !name) {
        name = query;
        query = window.location.href;
    }
    if ('[object String]' == Object.prototype.toString.call(query) & '[object String]' == Object.prototype.toString.call(name)) {
        var result = query.match(new RegExp("[\?\&]" + name + "=([^\&]+)", "i"));
        if (result == null || result.length < 1) {
            return "";
        }
        var r = result[1].replace(/#*$/, "");
        return decodeURIComponent(r);
    }
    return "";
}

/**
 * 如果sValue是空，则删除该name属性(新增)
 * @param query
 * @param name
 * @param sValue
 * @returns {string}
 * @constructor
 */
function SetQueryStringByName(query, name, sValue) {
    if (!!query == false) {
        name = query;
        query = window.location.href;
    }
    if (!!query) {
        var result = query.match(new RegExp("([\?\&]+)" + name + "=[^\&]*", "i"));
        var sRe = query;
        if (result != null) {
            sRe = query.replace(result[0], result[1] + name + "=" + encodeURI(sValue));
        }
        else {
            if (query.indexOf("?") < 0) {
                sRe = query + "?" + name + "=" + sValue;
            } else {
                sRe = query + "&" + name + "=" + sValue;
            }
        }
        result = sRe.match(new RegExp("([\?\&]+)" + name + "=[^\&]*", "i"));
        if(!sValue){
            sRe = sRe.replace(result[0], "");
        }
        return sRe;
    }
    return "";
}

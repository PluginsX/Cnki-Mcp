(function ($) {
    var fliter = function () { };

    //验证用户输入是否存在不允许字符
    fliter.doValidate = function (value) {
        var vkeyWords = /[<>\\\;]/im;

        if (vkeyWords.test(value)) {
            layer.alert(message['inputParmsError'], { btn: message.Confirm, title: message.info });
            return false;
        }

        return true;
    };

    //验证value是否有危险字符.有则返回true
    fliter.hasDangerousChar = function (value) {
        var vkeyWords = /[<>\\]/im;

        if (vkeyWords.test(value)) {
            return true;
        }
        return false;
    };

    //清除用户输入的不允许字符
    fliter.clearillegalChar = function (value) {
        if (value) {
            value = value.replace(/^\s+|[~!@$%^]+|\s+$/g, "");
        }
        if (value.length > 1000) {
            value = value.substring(0, 1000);
        }
        return value;
    };

    fliter.isCompositeExp = function (value) {
        var quoteStr = /^['\"][^'\"]+['\"]$/;

        // 操作符左右有值并且值不是操作符
        if (!quoteStr.test(value) && /[^\+\*\-\s]+\s+[\+\*\-]\s+[^\+\*\-\s]+/.test(value)) {


            var len = value.split("'").length - 1;
            var len2 = value.split("\"").length - 1;

            //  // 判断引号是否是成对的,判断括号是否是成对的
            if (len % 2 == 0 && len2 % 2 == 0 && fliter.isBrackBalance(value)) {
                return true;
            }
            else {
                return false;
            }
        }
        return false;
    };

    // 判断括号是否是成对的
    fliter.isBrackBalance = function (value) {
        if (!value) {
            return true;
        }

        if (value.indexOf("(") < 0 && value.indexOf(")") < 0) {
            return true;
        }

        // 去除引号里面的括号
        value = /['\"][^'\"]+['\"]/.replace(value, "*");
        var num = 0;
        for (var i = 0; i < value.length; i++) {
            if (value[i] == "(") {
                num++;
            }
            if (value[i] == ")") {
                num--;
            }
        }
        if (num == 0) {
            return true;
        }

        return false;
    }


    //验证用户输入的DOI
    fliter.ValidDOI = function (inputval, isprecise) {

        if (!inputval) {
            return false;
        }
        if (/^[\'\"]?10\./.test(inputval)) {

            //精确检索需要有斜线
            if (isprecise) {
                return /\//.test(inputval);
            }

            // 如果是复合检索，需要每个值都校验下
            //if (fliter.isCompositeExp(inputval)) {

            //}

            return true;
        }
        return false;
    };

    fliter.ValidExpertSearch = function (inputval) {
        var reg = /[=%]/ig
        if (!reg.test(inputval)) {
            return false;
        }

        // or and 两边不能是引号+空格，例如：AI='ad' or 'def'
        var linkchar = /\'\s(or|and)\s\'/i;
        if (linkchar.test(inputval)) {
            return false;
        }

        return true;
    };

    fliter.starYear = function (value) {
        value = value.replace(/[^\d]/g, '')
        if (value.length == 4) {
            if (value < 1979 && value != 1915 && value != 1949) {
                return "1949";
            }
            var cyear = new Date().getFullYear()

            if (value > cyear) {
                value = cyear
            }
        }
        return value;
    };

    fliter.endYear = function (value) {
        value = value.replace(/[^\d]/g, '')
        if (value.length == 4) {
            if (value < 1979 && value != 1915 && value != 1949) {
                return "1949";
            }
            var cyear = new Date().getFullYear()

            if (value > cyear) {
                value = cyear
            }
        }
        return value;
    }


    window.fliter = fliter
})(jQuery);



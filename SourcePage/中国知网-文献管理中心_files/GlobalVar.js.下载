(function ($) {
    function handlerstring(tempForm, data) {
        var arr = data.split('?');
        for (var i = 0; i < arr.length; i++) {
            var hideInput = document.createElement("input");
            hideInput.type = "hidden";
            hideInput.name = arr[i].substring(0, arr[i].indexOf("="));
            hideInput.value = arr[i].substring(arr[i].indexOf("=") + 1);
            tempForm.appendChild(hideInput);
        }
    }
    function handlerobject(tempForm, data) {
        for (var temp in data) {
            var hideInput = document.createElement("input");
            hideInput.type = "hidden";
            hideInput.name = temp;
            hideInput.value = data[temp];
            tempForm.appendChild(hideInput);
        }
    }
    //导出文本跳转页使用。data支持 a=1&b=3 或者{a:1,b:2} target：默认不传，当需要在本页面跳转的时候传_self
    $.PostWindow = function (url, data, target) {
        var tempForm = document.createElement("form");
        tempForm.id = "tempForm1";
        tempForm.method = "post";
        tempForm.action = url;
        tempForm.target = target ? target : "";
        if (typeof (data) == "object") {
            handlerobject(tempForm, data);
        }
        else if (typeof (data) == "string") {
            handlerstring(tempForm, data);
        }
        if (document.attachEvent) {
            tempForm.attachEvent("onsubmit", function () { window.open('about:blank') });
        }
        else if (document.addEventListener) {
            tempForm.addEventListener("onsubmit", function () { window.open('about:blank') });
        }
        document.body.appendChild(tempForm);
        tempForm.submit();
        document.body.removeChild(tempForm);
    }
    $.BrowserTab = function (funcactive, funcnoactive) {
        var hiddenProperty = 'hidden' in document ? 'hidden' :
            'webkitHidden' in document ? 'webkitHidden' :
                'mozHidden' in document ? 'mozHidden' :
                    null;
        if (hiddenProperty != null) {
            var visibilityChangeEvent = hiddenProperty.replace(/hidden/i, 'visibilitychange');
            var onVisibilityChange = function (funcactive, funcnoactive) {
                if (!document[hiddenProperty]) {
                    if (typeof funcactive == 'function')

    return this.replace(/^\s+/, '');
};
String.prototype.rtrim = function (str) {
    var reg = new RegExp('([' + str + ']*$)', 'gi');
    return str?this.replace(reg, ''):this.replace(/\s+$/, '');
};
String.prototype.trim = function () {
    return this.ltrim().rtrim();
};

    advWordsGuid.prototype._judgeRecommend = function (textInput, func) {
        var that = this;
        var j = 0;
        inputObj = $(textInput);
        callback = func;//把回调函数复制给公共变量
        mainSearch = inputObj.closest(".search-mainbox");
        rightSearch = mainSearch.siblings(".search-sidebar-b");
        reoptText = $.trim(inputObj.siblings(".reopt").find(".sort-default>span").text());

        reoptArr = Object.keys(message.RecommendIndex);//这些检索项有引导功能
        if (reoptArr.indexOf(reoptText) == -1) {
            rightSearch.find("dl.default-info").show().siblings().hide();//非引导项显示提示并隐藏引导框
            return false;
        }


        inputVal = !!inputObj.attr("searchWord") ? inputObj.attr("searchWord") : $.trim(inputObj.val());//input当前值
        tipID = inputObj.attr("data-tipID");//输入框标记的data-tipID，对应右侧推荐框的id
        //recommendInfoBox = rightSearch.find("#" + tipID);//与输入框对应右侧推荐框的id

        recommendInfoBox = rightSearch.find(".recommend-info");

        /* 1、输入框值为空，
        ** 2、存在不可编辑标志(class="disable-editor")，且右侧推荐列表已经不存在时，说明该输入框的值被编辑修改过，此时右侧不进行推荐，
        ** 3、直到不可编辑标志消失，继续进行推荐
        * */
        if (inputVal == "" || (inputObj.hasClass("disable-editor") && recommendInfoBox.length == 0)) {
            rightSearch.find(".default-info").show().siblings().hide();
        }
        else {
            var hideRecommendBox = $("#" + tipID);
            if (hideRecommendBox.length > 0 && (hideRecommendBox.attr("searchText") === $.trim(inputObj.val()) || inputObj.hasClass("disable-editor"))) {
                if (!hideRecommendBox.hasClass("noContent")) {//无内容不显示
                    recommendInfoBox.removeClass("recommend-info").hide();
                    hideRecommendBox.show().addClass("recommend-info").siblings().hide();
                }
                return;
            }

            var preTipID = recommendInfoBox.attr("id");
            if (preTipID !== tipID && hideRecommendBox.length == 0) {//保留上一次推荐结果
                var preInputObj = $("input[data-tipid='" + preTipID + "']");
                var preInputText = preInputObj.hasClass("disable-editor") ? preInputObj.attr("searchword") : preInputObj.val();
                recommendInfoBox.parent().append(recommendInfoBox.clone().removeClass("recommend-info").attr("searchText", preInputText))
                recommendInfoBox.removeClass("prototype");
            }
            else if (hideRecommendBox.length == 1) {
                hideRecommendBox.addClass("recommend-info").siblings().removeClass("recommend-info");
                recommendInfoBox = hideRecommendBox;
            }

            iconTop = inputObj.offset().top - inputObj.parents(".search-middle").offset().top + (inputObj.height() - 16) / 2; //.icon高16px
            recommendInfoBox.find(".icon-triangle").css("top", iconTop + "px");
            recommendInfoBox.attr("id", tipID);
            recommendInfoBox.find(".reopt-tit").text(reoptText);
            recommendInfoBox.find("ul.recommendList").empty();
            recommendInfoBox.find("ul.recommendList~div").hide();
            recommendInfoBox.attr("searchText", $.trim(inputObj.val()))
            that._matchListFormat(recommendInfoBox, reoptText, inputVal);
            //recommendInfoBox.show().siblings().hide();
        }

    }

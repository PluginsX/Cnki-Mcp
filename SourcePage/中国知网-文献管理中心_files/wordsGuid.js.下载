/*
 * 范围：高级检索、一框式检索
 * 功能：检索词引导
*/

var wordsGuid = (function () {
    function wordsGuid(recommendDiv, inputText) {
        this.recommendDiv = recommendDiv;
        this.inputText = inputText
    }

    var callback = '';//高级检索还原函数
    var mysearch;
    var inBrowser = typeof window !== 'undefined';
    var UA = inBrowser && window.navigator.userAgent.toLowerCase();
    var isIE = UA && /msie|trident/.test(UA);
    var isIE9 = UA && UA.indexOf('msie 9.0') > 0;
    var recommendApi = $("#hidRecommendApi").val();
    wordsGuid.prototype = {
        //初始化
        init: function () {
            var that = this;
            if (typeof (window.mysearch) !== "undefined") {
                mysearch = window.mysearch;
            }
            that.inputFunc();
            that.recommendCheckbox();
        },

        //清空提供引导的输入框的隐藏属性（代码，机构等）
        //obj：需清空的输入框对象
        clearInputAttr: function (obj) {
            obj.removeAttr('data-checkedcode');
            obj.removeAttr("data-field");
            obj.removeAttr('searchWord');
            obj.removeAttr('data-authorcode');
            obj.removeAttr('data-authorunit');
            obj.removeClass('disable-editor');
            obj.removeClass('is-input-error');
        },

        //清空提供引导的输入框对应的引导
        //obj：需清空的输入框对象
        clearRecommendBox: function (obj) {
            //清除对应推荐框
            var id = obj.attr("data-tipid");
            if (!!id) {
                $("#" + id).hide().siblings(".default-info").show();
                $("#" + id).remove();
            }

            if ($(".search-sidebar-b .recommend-info").length == 0) {
                $(".search-sidebar-b .prototype").addClass("recommend-info")
            }
        },

        //输入框事件
        inputFunc: function () {
            var that = this;
            var inputText = that.inputText;
            var recommendDiv = that.recommendDiv;
            var isCNInput = false;//中文输入标识

            //修改检索项 输入框清空 推荐模块隐藏
            $(".search-box").on("click", ".input-box .reopt li", function (e) {
                e.preventDefault();

                if ($(this).hasClass("prevCur")) {
                    $(this).removeClass("prevCur");
                    return;
                }
                else {
                    if (!$(this).hasClass("tit")) {
                        $(this).closest(".sort-list").find("li.prevCur").removeAttr("class");
                    }
                }

                var inputObj = $(this).closest(".input-box").find(":text");

                var _reoptText = $(this).text();

                //由检索项判断输入框默认值
                //if (_reoptText == message.CJFQLYFiled) {
                //    inputObj.attr("placeholder", message.CJFQLYFiled + "/ISSN/CN");
                //} else if (_reoptText == message.CCNDLYFiled) {
                //    inputObj.attr("placeholder", message.CCNDLYFiled + "/" + message.CN);
                //} else {
                //    inputObj.attr("placeholder", "");
                //}


                //inputObj.val("");
                that.clearInputAttr(inputObj);
                that.clearRecommendBox(inputObj);

                if (inputObj.siblings("a.btn-cleartext").length > 0) {
                    inputObj.siblings("a.btn-cleartext").hide();
                }
            })

            //input获取焦点
            $("body").on("focus", that.inputText, function (event) {
                event.preventDefault();

                // 不需要提示词的输入框
                var noneedtip = $(this).attr("noneedtip");
                if (noneedtip == "1") {
                    return;
                }

                var inputId = $(this).attr("data-tipid");
                var divId = $("div.recommend-info").attr('id');
                var text = $(this).val();
                var searchText = $(this).hasClass("disable-editor") ? $(this).attr("searchword") : $(this).val();
                var oneBoxRecom = $(this).siblings("div.droplist").find("li");

                if (!!text && text != $(this).attr("placeholder")) {
                    if ($(this).siblings("a.btn-cleartext").length > 0) {
                        $(this).siblings("a.btn-cleartext").show();
                    }
                }
                else {
                    oneBoxRecom.parent().empty();
                }

                var divObj = $(".recommend-info");
                if ((!!searchText === false) && (!!text === false)) {
                    //检索词不存在，不显示推荐
                    divObj.hide().siblings(".default-info").show();
                    return;
                }

                var hideDiv = $("#" + inputId);
                if (!!hideDiv && (hideDiv.attr("searchtext") === $.trim(searchText) || hideDiv.attr("searchtext") === $.trim(text))) {
                    //推荐已存在,且被引藏，不重新刷新，直接显示
                    if (!hideDiv.hasClass("noContent")) {
                        hideDiv.addClass("recommend-info").show().siblings().removeClass("recommend-info").hide();
                    }
                    else {
                        hideDiv.hide().siblings().hide().siblings(".default-info").show();
                    }
                    if (!!mysearch) {//仅高级检索mysearch才会初始化
                        mysearch._rightRecommendH();//计算右侧推荐列表高度;
                    }
                    return;
                }

                if (oneBoxRecom.length > 0) {
                    searchText = $(this).attr("searchword");
                    if (!!searchText) {
                        oneBoxRecom.closest("div.droplist").show();
                        return;
                    }
                }

                that._judgeRecommend(this);//根据检索词及input值是否存在，判断右侧推荐内容显示/隐藏
            });

            ////input移出焦点
            //$("body").on("blur", that.inputText, function (event) {
            //    event.preventDefault();
            //    var recommendDiv = that.recommendDiv;
            //    var inputText = that.inputText;
            //    $(document).click(function (event) {//鼠标未移到右侧推荐模块或左侧输入框中，右侧就恢复默认状态
            //        if ($(event.target).closest(inputText).length == 0 && $(event.target).closest(recommendDiv).length == 0 && $(event.target).closest(".popup-prompt").length == 0) {
            //            if ($(that.recommendDiv).find(".default-info").length > 0) {
            //                $(that.recommendDiv).find(".default-info").show().siblings().hide();
            //            }
            //            else {
            //                $(that.recommendDiv).hide();
            //            }
            //        }
            //    });
            //});

            //鼠标未移到右侧推荐模块或左侧输入框中，右侧就恢复默认状态
            $("body").on("mouseup", function (event) {
                var recommendDiv = that.recommendDiv;
                var inputText = that.inputText;
                if ($(event.target).closest(inputText).length == 0 && $(event.target).closest(recommendDiv).length == 0 && $(event.target).closest(".popup-prompt").length == 0) {
                    if ($(that.recommendDiv).find(".default-info").length > 0) {
                        $(that.recommendDiv).find(".default-info").show().siblings().hide();
                    }
                    else {
                        $(that.recommendDiv).hide();
                    }
                }
            })

            //推荐请求后台数据消抖
            //连续多次请求，只发送最后一次请求
            var debounce = function (fn, delay) {
                // 定时器，用来 setTimeout
                var timer;

                // 返回一个函数，这个函数会在一个时间区间结束后的 delay 毫秒时执行 fn 函数
                return function () {
                    // 保存函数调用时的上下文和参数，传递给 fn
                    var context = this
                    var args = arguments

                    clearTimeout(timer);

                    timer = setTimeout(function () {
                        fn.apply(context, args)
                    }, delay);
                }
            }

            //开始进行中文输入，设定中文输入标识
            $("body").on("compositionstart", that.inputText, function (event) {
                isCNInput = true;
            })

            //IE9下回退键（BackSpace），Delect键不触发input事件
            if (isIE9) {
                $("body").on("keyup", that.inputText, function (event) {
                    if (event.keyCode == 8 || event.keyCode == 46) {
                        $(this).trigger("input");
                    }
                })
            }

            $("body").on("input", that.inputText, debounce(function (event) {
                if (isCNInput) {
                    //中文输入不截断
                    return;
                }


                // 不需要提示词的输入框
                var noneedtip = $(this).attr("noneedtip");
                if (noneedtip == "1") {
                    return;
                }

                var obj = this;
                var $obj = $(obj);

                //选中后编辑或输入非空格时，清空已选项
                var text = $.trim($obj.val());
                var recommendText = $.trim($("#" + $obj.attr("data-tipid")).attr("searchtext"));
                if (text !== recommendText || $obj.hasClass("disable-editor")) {
                    that.clearInputAttr($obj);
                    that.clearRecommendBox($obj);
                }


                if ($obj.siblings("a.btn-cleartext").length > 0) {
                    if (!!$obj.val() && $obj.val() != $obj.attr("placeholder")) {
                        $obj.siblings("a.btn-cleartext").show();
                    }
                    else {
                        $obj.siblings("a.btn-cleartext").hide();
                        $(that.recommendDiv).hide();
                        return;
                    }
                }

                if ($obj.val().indexOf("+") == -1 && $obj.val().indexOf("（") == -1 && $obj.val().indexOf("(") == -1) {
                    $obj.removeClass("disable-editor");//若输入框内无+（(号，则恢复输入框的正常状态
                }

                if (!!$obj.attr("data-tipid")) {
                    var _id = $obj.attr("data-tipid");
                    $("#" + _id).hide();
                    if ($obj.hasClass("disable-editor")) {//含有这个class，说明不能编辑，若用户仍编辑，则对应的右侧边栏不再推荐内容,同时删除之前对应的右侧推荐列表

                        $("#" + _id).siblings(".default-info").show();
                        //$("#" + _id).remove();

                    } else {
                        that._judgeRecommend(obj);//根据检索词和input值，判断右侧推荐内容显示/隐藏、创建/移除
                    }
                }
                else {
                    if ($obj.hasClass("disable-editor")) {//含有这个class，说明不能编辑，若用户仍编辑，则对应的右侧边栏不再推荐内容,同时删除之前对应的右侧推荐列表
                        $(that.recommendDiv).hide();
                        $(that.recommendDiv).find("ul").empty();
                        return false;
                    } else {
                        that._judgeRecommend(obj);//根据检索词和input值，判断下拉框推荐内容显示/隐藏、创建/移除
                    }
                }
            }, 300));

            //中文输入结束 修改标识，提供推荐
            $("body").on("compositionend", that.inputText, function () {
                isCNInput = false;
            })

        },

        //推荐引导栏相关事件
        recommendCheckbox: function () {
            var that = this;
            var maxCheckCount = 5;//最大选中数量
            var checkedCount;

            //当此标识为true表示选中作者一级机构，取消选中作者二级机构或选中作者二级机构，取消选中作者一级机构，此时已选数量不改变
            var isChecedCountFlag = false;

            //返回检索词为“主题”、“作者”、“期刊名称”、“基金”···的列表或列表父级
            function _recommendParent(obj) {
                var recommendBox1 = $(obj).closest(".recommend-info-list");//检索词为“主题”、“作者”、“期刊名称”的列表对象
                var recommendBox2 = $(obj).closest(".recommend-fund-list");//检索词为“基金”的列表对象
                if (recommendBox1.length > 0)
                    return $(obj).closest(".recommend-info-list");
                else if (recommendBox2.length > 0)
                    return $(obj).closest(".recommend-fund-list");
                else
                    return $(obj).closest(".recommend-info");
            }

            //恢复input输入框初始状态
            function _recoverInput(btnObj) {
                var tipId = $(btnObj).closest(".recommend-info").attr("id");
                if (!!tipId) {
                    var textInput = $(btnObj).closest(".grade-search-content,.author-search-content").find("input[data-tipid='" + tipId + "']");
                    var initVal = $.trim(textInput.attr("searchWord"));
                    textInput.val(initVal);
                    textInput.removeClass("disable-editor");
                    that.clearInputAttr(textInput);
                }
            }

            //右侧“同名作者/所在机构”导航层级的折叠/展开事件
            $(that.recommendDiv).unbind("click").on("click", ".icon", function () {
                var itemNode = $(this).parent();      //".item-nav"
                itemNode.toggleClass("is-down");

                if (itemNode.hasClass("is-down")) {
                    itemNode.next("ul").slideDown();
                } else {
                    itemNode.next("ul").slideUp();
                }
            });

            //清除所有input[type=checkbox]选中状态
            $(that.recommendDiv).on("click", ".btn-clear-selected", function () {
                recommendBox = _recommendParent(this); //检索词为“主题”、“作者”、“期刊名称”、“基金”的列表对象
                recommendBox.find("input[type=checkbox]:checked").each(function(){
                    $(this).click();//点击才能彻底清除
                })
                var id = $(this).parents(".recommend-info").attr("id");
                var inputBox = $("input[data-tipid='" + id + "']");
                if (!!inputBox.hasClass("disable-editor")) {
                    _recoverInput(this);//恢复input输入框初始状态
                }
                recommendBox.find("label").removeClass("selected");
                $(".popup-prompt").remove();
            });

            //选中复选框，数量不超过maxCheckCount
            $(that.recommendDiv).on("click", "ul.recommendList input[type=checkbox]", function () {
                var authorRemove = function (obj, removeCode) {

                    isChecedCountFlag = true;

                    obj.find(":checked").prop("checked", false);
                    obj.find("label").removeClass("selected");

                    //移除父级机构保存的值
                    var spanObj = obj.find("span.organ");
                    var temp = '';
                    //修改隐藏代码值
                    var objVal = textInput.attr(removeCode);
                    $.each(spanObj, function () {
                        objVal = objVal.replace($.trim($(this).attr("value")), "");
                    })
                    var objValArr = objVal.split("+");
                    for (var i = 0, len = objValArr.length; i < len; i++) {
                        if (!!objValArr[i]) {
                            temp += objValArr[i] + "+";
                        }
                    }
                    textInput.attr(removeCode, temp.substring(0, temp.length - 1));
                    //修改输入框值
                    var inputText = textInput.val();
                    $.each(spanObj, function () {
                        inputText = inputText.replace($.trim($(this).text()), "");
                    })
                    var inputValArr = inputText.split("+");
                    temp = '';
                    for (var i = 0, len = inputValArr.length; i < len; i++) {
                        if (!!inputValArr[i]) {
                            if (i == len - 1 || $.trim(objValArr[i]) == "）")
                                temp += inputValArr[i];
                            else
                                temp += inputValArr[i] + "+";
                        }
                    }
                    textInput.val(temp);
                }

                var _getAuthorInputVal = function () {//将右侧选中的推荐作者机构添加到左侧对应的输入框内,返回输入框值
                    if (oldVal.indexOf("（") == -1 && oldVal.indexOf("(") == -1)
                        return oldVal + "（" + organText + "）";
                    else {
                        return _analyAuthorArr(valArr);
                    }
                }

                var _analyAuthorArr = function (arr) {//解析数组，返回对应输入框的值
                    text = "";
                    if (arr.length == 1)
                        return arr[0];
                    else {
                        for (var j = 0, len = arr.length; j < len; j++) {
                            if (j != 0) //排除数组第一个值
                                text += j == 1 ? arr[j] : (" + " + arr[j]);
                        }
                        return arr[0] + "（" + text + "）";
                    }
                }

                var _clearArrBlank = function (val, isAuthor) {//将val通过+()（）号分隔，除去空格和空值，获得新数组
                    var arr = new Array();
                    if (isAuthor) {
                        //只有作者才按括号拆分
                        var defaultValArr = [];
                        if (val.indexOf("（") == 3) {//机构中含有括号
                            defaultValArr.push(val.substring(0, 3));
                            defaultValArr = defaultValArr.concat(val.substring(4, val.length - 1).split(/[+]/));
                        } else {
                            defaultValArr = val.split(/[+()（）]/);
                        }

                    }
                    else {
                        var defaultValArr = val.split(/[+]/);
                    }

                    for (var i = 0; i < defaultValArr.length; i++) {
                        if (!$.trim(defaultValArr[i]) == "")
                            arr.push($.trim(defaultValArr[i]));
                    }
                    return arr;
                }

                var _indexArr = function (array, val) {//获取数组array中val的索引值
                    for (var i = 0; i < array.length; i++) {
                        if ($.trim(array[i]) == val) return i;
                    }
                    return -1;
                }

                var _removeArr = function (array, val) {//移除数组array中的val
                    var index = _indexArr(array, val);
                    if (index > -1) {
                        array.splice(index, 1);
                    }
                }


                var recommendBox = _recommendParent(this); //检索词为“主题”、“作者”、“期刊名称”、“基金”的列表对象

                //判断是否为“同名作者 / 所在机构”列表
                //注：选中作者推荐列表项，左侧对应输入框的展示格式与其它几个不同
                var isAuthorList = recommendBox.attr("class").indexOf("authorlist") > -1;
                var isThemeList = recommendBox.hasClass("js-recommend-themelist");

                var tipId = $(this).closest(".recommend-info").attr("id");
                var datafield = $(this).parents("ul.recommendList").attr("data-field");
                var textInput = $(this).closest(".grade-search-content,.author-search-content").find("input[data-tipid='" + tipId + "']");
                if (textInput.length == 0) {
                    //一框式检索
                    textInput = $(that.inputText);
                }

                checkedCount = !!textInput.val() ? textInput.val().split("+").length : 0;
                if (isThemeList) {
                    checkedCount--;
                }

                if (isAuthorList) {//作者
                    var authorAttribut;
                    if (!textInput.attr("data-authorcode") && !textInput.attr("data-authorunit")) {
                        textInput.attr("searchWord", $.trim(textInput.val()));
                    }
                    if ($(this).parents("ul").siblings("div.item").length == 0) {
                        //选择一级代码
                        var childObj = $(this).parents("div.item").siblings("ul");
                        if (!!childObj.find(":checked").length > 0) {
                            //取消子级机构选中
                            authorRemove(childObj, "data-authorunit");
                        }
                        authorAttribut = "data-authorcode";
                    }
                    else {
                        //选择二级代码
                        var parentObj = $(this).parents("ul").siblings("div.item");//父级机构
                        if (!!parentObj.find(":checked").length > 0) {
                            authorRemove(parentObj, "data-authorcode");
                        }
                        authorAttribut = "data-authorunit";
                    }
                    var oldCodeVal = textInput.attr(authorAttribut);//隐藏的代码值
                    var codeValArr = !!oldCodeVal ? _clearArrBlank(oldCodeVal, isAuthorList) : [];
                    var thisCode = $.trim($(this).siblings("span.organ").attr("value"));
                    var oldVal = textInput.val();
                }
                else {//非作者
                    var oldCodeVal = textInput.attr("data-checkedcode");//隐藏的代码值
                    var codeValArr = !!oldCodeVal ? _clearArrBlank(oldCodeVal, isAuthorList) : [];
                    var thisCode = $.trim($(this).attr("value"));
                    var oldVal;
                    if (!!oldCodeVal) {
                        oldVal = textInput.val();
                    }
                    else {
                        oldVal = "";
                        textInput.attr("searchWord", $.trim(textInput.val()));//勾选后储存用户检索词
                    }
                }

                var parentLabel = $(this).closest("label");
                var authorName = textInput.attr("searchWord");
                var re = new RegExp(authorName, "g");
                if (isAuthorList) {
                    oldVal = $.trim(oldVal).replace(re, "<$>")//如果是作者，将作者名用特殊符号代替（部分作者名字中含有括号）
                    var organ = oldVal.substring(3).replace(/\<\$\>/g, authorName);//防止机构名中含有作者名 如 张（张掖大学）
                    oldVal = "<$>" + organ
                }

                var valArr = _clearArrBlank(oldVal, isAuthorList);//将当前值转换成数组，并清除前后空格和空值
                var thisText = $.trim(parentLabel.text());


                var newVal;
                if (parentLabel.hasClass("selected")) {//取消选中
                    parentLabel.removeClass("selected"); //移除selected
                    checkedCount--;

                    if (isAuthorList) {//作者
                        organText = $.trim(parentLabel.find(".organ").text());//机构名称
                        _removeArr(valArr, organText); //数组中移除与点击的字符串匹配的值
                        newVal = _analyAuthorArr(valArr).replace("<$>", authorName);
                        textInput.val(newVal);

                        //移除隐藏域中保存的code值
                        _removeArr(codeValArr, thisCode); //数组中移除与该字符串匹配的值
                        newVal = "";
                        for (var j = 0, len = codeValArr.length; j < len; j++) {
                            newVal += j == 0 ? codeValArr[j] : ("+" + codeValArr[j]);
                        }
                        textInput.attr(authorAttribut, newVal)

                    } else { //非作者
                        _removeArr(valArr, thisText); //数组中移除与该字符串匹配的值
                        newVal = "";
                        for (var j = 0; j < valArr.length; j++) {
                            newVal += j == 0 ? valArr[j] : (" + " + valArr[j]);
                        }
                        textInput.val(newVal);

                        //移除隐藏域中保存的code值
                        _removeArr(codeValArr, thisCode); //数组中移除与该字符串匹配的值
                        newVal = "";
                        for (var j = 0, len = codeValArr.length; j < len; j++) {
                            newVal += j == 0 ? codeValArr[j] : ("+" + codeValArr[j]);
                        }
                        textInput.attr("data-checkedcode", newVal)
                    }
                    if (valArr.length <= 1) textInput.removeClass("disable-editor");//对应的input值恢复黑色，表示可编辑

                }
                else if (checkedCount < maxCheckCount || isChecedCountFlag) {
                    parentLabel.addClass("selected");//添加selected
                    if (isAuthorList) {//作者
                        organText = $.trim(parentLabel.find(".organ").text());//机构名称
                        valArr.push(organText);
                        newVal = _getAuthorInputVal().replace("<$>", authorName);//解析数组，计算对应输入框的值
                        textInput.val(newVal);

                        //储存选中项代码
                        codeValArr.push(thisCode);
                        newVal = !!oldCodeVal ? oldCodeVal + "+" + thisCode : thisCode;
                        textInput.attr(authorAttribut, newVal);
                    } else { //非作者
                        valArr.push(thisText);
                        newVal = !!oldCodeVal ? oldVal + " + " + thisText : thisText;
                        if (isThemeList && !oldCodeVal) {//主题引导，勾选后不移除输入词
                            textInput.val(textInput.attr("searchWord") + " + " + newVal);
                        } else {
                            textInput.val(newVal);
                        }

                        //储存选中项代码
                        codeValArr.push(thisCode);
                        newVal = !!oldCodeVal ? oldCodeVal + "+" + thisCode : thisCode;
                        textInput.attr("data-checkedcode", newVal);
                    }
                    if (!textInput.attr("data-field")) {
                        textInput.attr("data-field", datafield)
                    }
                    textInput.addClass("disable-editor");//对应的input值变为灰色，表示不可编辑
                }
            });


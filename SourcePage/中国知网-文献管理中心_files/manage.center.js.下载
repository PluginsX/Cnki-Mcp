    function getQueryIDArray() {
        var arr = new Array();
        var filename = get();
        if (!filename) return arr;
        var tempArr = filename.split(",");
        for (var i = 0; i < tempArr.length; i++) {
            var a = tempArr[i].split("!");
            if (a.length == 4 && arr.indexOf(a[3]) == -1) {
                arr.push(a[3]);
            }
        }
        return arr;
    }

    var searchInfo = {
        saveKey: "SEARCHINFO"+ getUniplatform() ,
        keyCollection: new Array(),
        valueCollection: new Array(),
        //    updateTimeCollection: new Array(),
        count: 0,
        get: function () {
            return this.getCahce(this.saveKey, _StorageType) || $("#sqlVal").val() || "";
        },
        init: function () {
            if (!this.isExistFileNames()) {
                this.clear();
                return;
            }
            var ts = this.get();
            if (Object.prototype.toString.call(ts) == "[object String]" && ts != "") {
                this.splitInfoStr(ts);
                this.updataCount();
                this.save();
            }
            else {
                if (Object.prototype.toString.call(this.emptyCallBackFun) == "[object Function]") {
                    this.emptyCallBackFun();
                }
            }
        },
        updataCount: function () {
            this.count = this.keyCollection.length;
        },
        splitInfoStr: function (input) {
            if (typeof input == "string") {
                var mArr = input.split(",");
                var i = mArr.length;
                if (i > 0) {
                    while (i--) {
                        this.fillKV(mArr[i]);
                    }
                }
            }
        },
        fillKV: function (v) {
            if (typeof v == "string") {
                var sArr = v.split("!");
                if (sArr.length < 3)
                    return;
                var index = this.indexOfValue(sArr[1] + "!" + sArr[2]);
                if (index > -1) {   //如果有相同的sql值，则更新queryid,并且fielname的queryid需要更新
                    var temp = parseInt(this.keyCollection[index]);
                    this.keyCollection.splice(index, 1);
                    this.valueCollection.splice(index, 1);
                    this.keyCollection.push(sArr[0]);
                    this.valueCollection.push(sArr[1] + "!" + sArr[2]);
                    return;
                }
                var t = this.indexOf(sArr[0]);
                //if Exist to Replace ,Reason: new
                if (t >= 0 && sArr[2]) {// && this.updateTimeCollection[t] != "") {
                    this.keyCollection[t] = sArr[0];
                    this.valueCollection[t] = sArr[1] + "!" + sArr[2];
                    return;
                }
                this.keyCollection.push(sArr[0]);
                this.valueCollection.push(sArr[1] + "!" + sArr[2]);
                this.updataCount();
            }
        },
        indexOf: function (k) {
            if (this.count > 0) {
                var i = this.count;
                while (i--) {
                    if (this.keyCollection[i] == k) {
                        return i;
                    }
                }
            }
            return -1;
        },
        indexOfValue: function (v) {//sql一样，不存储
            if (this.count > 0) {
                var i = this.count;
                while (i--) {
                    if (v == this.valueCollection[i]) {
                        return i;
                    }
                }
            }
            return -1;
        },
        index: function (filename) {//sql一样，不存储
            var filenameObj="";
            $(".manage-table tr").each(function (i,obj) {
                if($(obj).find("input").attr("value")==filename){
                    filenameObj=$(obj);
                    return false;
                }
            })
            var condition =$(filenameObj).prevAll(".condition").length==1?$(filenameObj).prevAll(".condition").find("td").text().trim("\n"):
                $(filenameObj).prevAll(".condition:eq(0)").find("td").text().trim("\n");
            condition=condition?condition.substring(condition.indexOf(":")+1):condition;
            if (this.count > 0) {
                var i = this.count;
                while (i--) {
                    if (this.valueCollection[i].endWith(condition)) {
                        return this.keyCollection[i];
                    }
                }
            }
            return -1;
        },
        isExist: function (v) {
            if (this.indexOfValue(v) >= 0) {
                return true;
            }
            return false;
        },
        getV: function (k) {
            var t = this.indexOf(k);
            if (t >= 0) {
                return this.valueCollection[t];
            }
            return "";
        },
        addKV: function (k, v) {
            var index = this.indexOfValue(v);
            if (index > -1) {   //如果有相同的sql值，则更新queryid,并且fielname的queryid需要更新
                var temp = parseInt(this.keyCollection[index]);
                this.keyCollection.splice(index, 1);
                this.valueCollection.splice(index, 1);
                this.keyCollection.push(k);
                this.valueCollection.push(v);
                this.save();
                return temp;
            }
            var t = this.indexOf(k);
            //if Exist to Replace ,Reason: new
            if (t >= 0 && v) {// && this.updateTimeCollection[t] != "") {
                this.keyCollection[t] = k;
                this.valueCollection[t] = v;
            }
            //else add
            else {
                this.keyCollection.push(k);
                this.valueCollection.push(v);
            }
            this.updataCount();
            this.save();
            return '';
        },
        getCahce: function (k, t) {
            if (window.localStorage) {
                if (t == StorageType.Session) {
                    return window.sessionStorage.getItem(k);
                }
                else {
                    return window.localStorage.getItem(k)
                }
            }
            else {
                return getCookie(k);
            }
        },
        remove: function (k) {
            var t = this.indexOf(k);
            if (t >= 0) {
                this.keyCollection = this.deletArray(this.keyCollection, t);
                this.valueCollection = this.deletArray(this.valueCollection, t);
                this.updataCount();
                this.save();
            }
        },
        deletArray: function (arr, pos) {
            return arr.slice(0, pos).concat(arr.slice(++pos));
        },
        save: function (t) {
            var v = this.getStr();
            var k = this.saveKey;
            if (window.localStorage) {
                if (t == StorageType.Session) {
                    window.sessionStorage.setItem(k, v);
                }
                else {
                    window.localStorage.setItem(k, v)
                }
            }
            else {
                setCookie(k, v, t);
            }
        },
        clear: function () {
            this.count = 0;
            this.keyCollection = new Array();
            this.valueCollection = new Array();
            this.save();
        },
        isExistFileNames: function () {
            var filename = get();
            if (!filename) {
                return false;
            }
            return true;
        },
        getStr: function () {
            var i = this.count;
            var tempStr = "";
            while (i--) {
                if (this.keyCollection[i] && this.valueCollection[i]) {
                    tempStr += "{0}!{1},".format(this.keyCollection[i], this.valueCollection[i]);
                }
            }
            if (tempStr.length > 0) {
                tempStr = tempStr.substring(0, tempStr.length - 1);
            }
            return tempStr;
        },
        emptyCallBackFun: function () {
        },
        //新增了个条件的时候，此时的index值为最大的数加1
        getNextIndex:function(){
            var result=0;
            for(var i=0;i<this.keyCollection.length;i++){
                if(result<this.keyCollection[i]){
                    result=this.keyCollection[i];
                }
            }
            return parseInt(result)+1;
        },
    }
    var searchAndFilenameIndex = {
        saveKey: "filenameIndex" + getUniplatform() ,
        init: function () {
            var arrIndexs =JSON.parse(this.get()) ;
            var searhinfos = $.searchinfoGet();
            var filenames = $.filenameGet();
            if(!searhinfos||!filenames){
                this.save("");
                return;
            }
            var arrSearchinfo=searhinfos.split(",");
            var arrFilenames=filenames.split(",");
            var arrIndex;
            if (!arrIndexs) {
                arrIndex = new Array();
                arrIndexs = {};
                for(var i=0;i<arrFilenames.length;i++){
                    arrIndex.push(i+1);
                }
                arrIndexs[arrSearchinfo[0].split("!")[0]] = arrIndex;
            } else {
                var count=0;
                for(var searhInfoIndex in arrIndexs){
                    count+=arrIndexs[searhInfoIndex].length;
                }
                if (count!=arrFilenames.length) {
                    arrIndex = new Array();
                    arrIndexs = {};
                    for(var i=0;i<arrFilenames.length;i++){
                        arrIndex.push(i+1);
                    }
                    arrIndexs[arrSearchinfo[0].split("!")[0]] = arrIndex;
                }
            }
            this.save(arrIndexs);
        },
        get: function () {
            function getCahce(k, t) {
                if (window.localStorage) {
                    if (t == StorageType.Session) {
                        return window.sessionStorage.getItem(k);
                    }
                    else {
                        return window.localStorage.getItem(k)
                    }
                }
                else {
                    return getCookie(k);
                }
            }
            return getCahce(this.saveKey, _StorageType) ;
        },
        add: function (searchInfoIndex, fileNameIndex) {
            if(searchInfoIndex<=-1||fileNameIndex<=-1){
                return;
            }
            var arrIndexs =JSON.parse(this.get()) ;
            var arrIndex;
            if (!arrIndexs) {
                arrIndex = new Array();
                arrIndexs = {};
                arrIndexs[searchInfoIndex] = arrIndex;
            } else {
                if (!arrIndexs[searchInfoIndex]) {
                    arrIndex = new Array();
                    arrIndexs[searchInfoIndex] = arrIndex;
                } else {
                    arrIndex = arrIndexs[searchInfoIndex];
                }
            }
            if (!arrIndex) {
                arrIndex.push(fileNameIndex);
            } else {
                var index = arrIndex.indexOf(fileNameIndex);
                if (index == -1) {
                    arrIndex.push(fileNameIndex);
                }
            }
            if (arrIndex.length == 0) {
                delete arrIndexs[searchInfoIndex]
                this.save(arrIndexs);
            } else {
                arrIndexs[searchInfoIndex] = arrIndex;
                this.save(arrIndexs);
            }
        },
        del: function (searchInfoIndex, fileNameIndex) {
            var arrIndexs =JSON.parse(this.get()) ;
            var arrIndex;
            if (!arrIndexs) {
                arrIndex = new Array();
                arrIndexs = {};
                arrIndexs[searchInfoIndex] = arrIndex;
            } else {
                if (!arrIndexs[searchInfoIndex]) {
                    arrIndex = new Array();
                    arrIndexs[searchInfoIndex] = arrIndex;
                } else {
                    arrIndex = arrIndexs[searchInfoIndex];
                }
            }
            var index = arrIndex.indexOf(fileNameIndex);
            if (index > -1) {
                arrIndex.splice(index, 1);
                for(var searhInfoIndex in arrIndexs){
                    for(var i=0;i<arrIndexs[searhInfoIndex].length;i++){
                        if(arrIndexs[searhInfoIndex][i]>fileNameIndex){
                            arrIndexs[searhInfoIndex][i]=arrIndexs[searhInfoIndex][i]-1;
                        }
                    }
                }
            }

            if (arrIndex.length == 0) {
                delete arrIndexs[searchInfoIndex]
                this.save(arrIndexs);
            } else {
                arrIndexs[searchInfoIndex] = arrIndex;
                this.save(arrIndexs);
            }
        },
        save: function (v,saveType) {
            var k = this.saveKey;
            if (window.localStorage) {
                if (saveType == StorageType.Session) {
                    if(!v){
                        window.sessionStorage.removeItem(k);
                    }else{
                        window.sessionStorage.setItem(k, JSON.stringify(v));
                    }
                }
                else {
                    if(!v){
                        window.localStorage.removeItem(k);
                    }else{
                        window.localStorage.setItem(k, JSON.stringify(v))
                    }
                }
            }
            else {
                setCookie(k, JSON.stringify(v));
            }
        },
    }
    //点击选中或者取消选中文献 包括全选
    $.fn.filenameClick = function () {
        searchInfo.init();//防止同时打开多个页面的时候没有更新searchinfo导致queryid不一致
        var t = $(this).attr("name") == "CookieName" ? $(this).val() : $("input[name='CookieName']")[0].value;
        if (!t) {
            $(this).prop("checked", false);
            return;
        }
        var k=1;
        if ($(".result-con-l .search-his-tip .range").length == 1) {
            var condition=$(".result-con-l .search-his-tip .range").text() + "!" + $(".result-con-l .search-his-tip .conditions").text();
            if(searchInfo.isExist(condition)){
                k=searchInfo.indexOfValue(condition);
            }else {
                k=searchInfo.getNextIndex();
                searchInfo.addKV(k,condition );
            }
        } else if ($("#SearchHisTip").length == 1) {
            var condition = $.trim($(".SearchHisTip").text());
            condition = condition ? (condition.endWith("x") ? condition.substring(0, condition.length - 1) : condition) : $.showSearchCondition(cnkiSearch.getRootQueryGroup(cnkiSearch.GroupName.SUBJECT), true);
            if(searchInfo.isExist(condition)){
                k=searchInfo.indexOfValue(condition);
            }else {
                k=searchInfo.getNextIndex();
                searchInfo.addKV(k, $("#dbTag .recur a").text() + "!" + condition);
            }
        }
        if ($(this).prop("checked")) {
            if ($(this).attr("name") == "CookieName") {
                if ($.filenameCount() >= 500) {
                    alert(message.most100);
                    $(this).prop("checked", false);
                    return false;
                }
                add($(this).val());
                setCheckAll();
            }
            else {
                checkAll(this);
            }
        }
        else {
            if ($(this).attr("name") == "CookieName") {
                del($(this).val());
                setCheckAll();
            }
            else {
                checkAll(this);
            }
            delSelect(this);
        }
        setSelect();
        $("#selectCount,#anisys_select span").text($.filenameCount());
        $("#batchOpsBox>li:eq(0)>span").text(message.selected + "(" + $.filenameCount() + ")");

    }

function initTable() {
    var obj = $("#manage-table tbody tr");
    var index = 1, length = 0;
    var arr = [];
    $(obj).each(function () {
        if ($(this).find("td").length == 1) {
            if (arr.indexOf($(this).find("td").html()) > -1) {
                $(this).remove();
            } else {
                index = 1;
            }
            arr.push($(this).find("td").html());
            return true;
        }
        $(this).find("td.seq em").click(function () {
            $(this).parent().find("input[type='checkbox']").click();
        })
        $(this).find("td.seq em").text(index);
        index++;
        length++;
    });
    $("#batchOpsBox em:eq(0)").text($.filenameCount());
    $("#batchOpsBox em:eq(1)").text(length);
    var count = 0;
    $.each($(".manage-table").find('input[name="CookieName"]:checked'), function () {
        count++;
    });
    $("#batchOpsBox>li:eq(0)>span").text(message.selected + "（" + count + "）");
    $("#anisys_select span").text(length);

    //初始化条件
    $(obj).find(".condition").each(function () {
        if ($(this).parent().next().find("td").length <= 1)
            $(this).parent().remove();
    })

}

function RemoveRepeat() {
    var obj = $("#manage-table tbody tr");
    var arrFilename = [], arrYxFilename = [];
    $(obj).each(function () {
        var item = $(this).find("td.seq input");
        if (!item || item.length == 0) {
            return true;
        }
        if (arrFilename.indexOf($(item).attr("filename")) > -1) {
            $(this).remove();
            return true;
        }
        arrFilename.push($(item).attr("filename"));
        if (!$(item).attr("yxfilename")) {
            return true;
        }
        if (arrYxFilename.indexOf($(item).attr("yxfilename")) > -1) {
            $(this).remove();
            return true;
        }
        arrYxFilename.push($(item).attr("yxfilename"));
    });
}

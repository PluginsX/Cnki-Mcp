    //当sql语句的queryid变化，但语句没变化的时候，修改filename的queryid值，使得可以匹配sql语句
    function setFileNameNumber(oldValue, NewValue) {
        var arr = new Array();
        var filename = get();
        if (!filename) return;
        var replace = function (input, old, value) {
            var re = new RegExp("!" + old + ",", "ig");
            input = input.replace(re, "!" + value + ",");
            re = new RegExp("!" + old + "$", "ig");
            input = input.replace(re, "!" + value);
            return input;
        }
        filename = replace(filename, oldValue, NewValue);
        addCache(_FileNameKey, filename, _StorageType);
    }

    function get(key) {
        if (window.localStorage) {
            this.getFileNameS = function (n, t) {
                var tmp = "";
                if (t == StorageType.Session) {
                    tmp = window.sessionStorage.getItem(n);
                }
                else {
                    tmp = window.localStorage.getItem(n);
                }
                return tmp == null ? "" : tmp;
            }
        }
        else {
            this.getFileNameS = function (n, v) {
                return $.cookie(n);
            }
        }
        key = key ? key : _FileNameKey;
        return this.getFileNameS(key, _StorageType);
    }

    function addCache(n, v, t) {
        if (window.localStorage) {
            this.setFileNameS = function (n, v, t) {
                if (t == StorageType.Session) {
                    window.sessionStorage.setItem(n, v);
                }
                else {
                    window.localStorage.setItem(n, v)
                }
            }
        }
        else {
            this.setFileNameS = function (n, v, t) {
                $.cookie(n, v);
            }
        }
        this.setFileNameS(n, v, t);
    }

    function add(value) {
        var filename = get();
        var bool = ifExists(value);
        if (bool)
            return false;
        if(_FileNameKey== "FileNameS" + getUniplatform() ){
            var fileNameIndex=filename?filename.trim(",").split(",").length+1:1;
            var searinfoIndex=searchInfo.index(value);
            searchAndFilenameIndex.add(searinfoIndex,fileNameIndex);
        }
        if (filename)
            value = filename + "," + value;
        addCache(_FileNameKey, value, _StorageType);
        return true;
    }

    function del(value) {
        var handlerRegexChar = handlerRegexSpcileChar;

        var deleteV = function (input, value) {
            var re = new RegExp("," + handlerRegexChar(value) + ",");
            input = ("," + input + ",").replace(re, ",");
            while (input.length != 0) {
                if (input.startWith(","))
                    input = input.substring(1);
                if (input.endWith(","))
                    input = input.substring(0, input.length - 1);
                if (input.indexOf(",,") > -1)
                    input = input.replace(",,", ",");
                if (!input.startWith(",") && !input.endWith(",") && input.indexOf(",,") == -1)
                    break;
            }
            return input;
        }
        var filename = get();
        //初始化ai的已选文献
        $.filenameAIInit();
        if (_FileNameKey == "FileNameS" + getUniplatform()  && (!filename || filename.length <= 0)) {
            $.searchinfoInit();
            $.filenameInit();
            return false;
        }

        var tableFileNames = getTableNameFileNames(value);
        if (tableFileNames.length <= 0) {
            filename = deleteV(filename, "");
            addCache(_FileNameKey, filename, _StorageType);
            return false;
        }

        if(_FileNameKey == "FileNameS" + getUniplatform() ){
            var arrFilename=filename.trim(",").split(",");
            var fileNameIndex=arrFilename.indexOf(value)+1;
            //此处拿到的index是keyCollection的值，不需要再加1，中心网站的拿到的是index值，需要加1
            var searinfoIndex=searchInfo.index(value);
            searchAndFilenameIndex.del(searinfoIndex,fileNameIndex);
        }
        //CJFD0305!ZFLT200504008[^,]*
        tableFileNames = handlerRegexChar(tableFileNames);
        var re = new RegExp(tableFileNames + "[^,]*", "ig");

        var tempMaths = filename.match(re);
        if (tempMaths && tempMaths.length > 0) {
            for (var i = 0; i < tempMaths.length; i++) {
                filename = deleteV(filename, tempMaths[i]);
            }
            addCache(_FileNameKey, filename, _StorageType);
            if (_FileNameKey == "FileNameS" + getUniplatform()  && (!filename || filename.length <= 0)) {
                $.searchinfoInit();
            }
            return true;
        }
        return false;
    }

    //当文献取消选中的时候，需要查看在selectFilenames中是否有，有则去掉

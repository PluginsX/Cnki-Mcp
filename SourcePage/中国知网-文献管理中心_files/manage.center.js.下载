/**
 * 获取平台值 和 学科分类(如果有值的情况下)
 *
 * @returns {string|string}
 */
function getUniplatform() {
    var uniplatform = $.getUniplatform();
    var subject = $.getSubject();
    return subject? uniplatform.toUpperCase()+subject.toUpperCase() :uniplatform.toUpperCase();
}



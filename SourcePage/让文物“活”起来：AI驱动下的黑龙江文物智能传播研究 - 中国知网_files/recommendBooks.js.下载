!(function WriteRelatedbooks() {
  bookStoreFuns.addCss(bookStoreData.relatedCss);
  var hasloadBookJS = false;
  $(window).scroll(function () {
    try {
      // 获取目标元素
      var targetElement = $(bookStoreData.relatedIdName);
      if (targetElement.length === 0) {
        return;
      }
      // 获取目标元素相对于文档顶部的位置
      var targetOffsetTop = targetElement.offset().top;
      // 获取当前滚动位置
      var scrollTop = $(window).scrollTop();
      // 获取窗口高度
      var windowHeight = $(window).height();

      // 检查目标元素是否出现在可视区域
      if (scrollTop + windowHeight >= targetOffsetTop && !hasloadBookJS) {
        console.log('滚动到--开始调用');
        hasloadBookJS = true;
        setTimeout(function () {
          try {
             var code = bookStoreFuns.GetScriptSrcQueryString(bookStoreData.fileName+"?", "code");
             var keyword = bookStoreFuns.GetScriptSrcQueryString(bookStoreData.fileName+"?", "keyword");
             var subject = bookStoreFuns.GetScriptSrcQueryString(bookStoreData.fileName+"?", "subject");
            //动态获取数据并渲染到指定位置
            bookStoreFuns.requestRelatedList({code,keyword,subject});
          }
          catch (e) {
            bookStoreFuns.consoleAd('setTimeout 内部异常: ' + e.message);
          }
        }, 100);
      }
    } catch (e) { }
  });
})();

var bookStoreFuns = {
  //解析出参数
  GetScriptSrcQueryString: function(jsfilename, name) {
      if (name == null || name == "")
          return null;
      var reg = new RegExp("(^|&)" + name + "=([^&]*)(&|$)");
      var dscriptSrc = bookStoreFuns.FindScriptSrc(jsfilename);
      var scriptsrc = dscriptSrc.substr(dscriptSrc.indexOf("?") + 1);
      var r = scriptsrc.match(reg);
      if (r != null) return decodeURIComponent(r[2]); return null;
  },
  FindScriptSrc: function(jsfilename) {
    var src = "";
    var scriptArr = document.scripts;
    for (var i = 0; i < scriptArr.length; i++) {
        if (scriptArr[i].src.indexOf(jsfilename) > -1) {
            src = scriptArr[i].src;
            break;
        }
    }
    return src;
  },
  //输出广告的样式表
  addCss: function(value) {
    try {
      var newcss = '';
      newcss = value
      document.writeln(newcss);
    } catch (e) { }
  },
  // 从隐藏input中读取fileId和productId参数
  getHiddenInputParams: function(queryObj) {
    var fileId = $('#param-filename').val();
    var productId = $('#param-dbcode').val();
    if(fileId) {
      queryObj.fileId = fileId;
    }
    if(productId) {
      queryObj.productId = productId;
    }
    return queryObj;
  },
  requestHotList: function(query) {
    console.log('requestHotList---请求数据');
    var adReqUrl = bookStoreData.baseUrl+'/bookstore-shop/zongku-recommend/hot-books';
    let queryObj={};
    if(query == null || query == ""){
      queryObj={};
    }else{
      queryObj=query;
    }
    // 从隐藏input中读取fileId和productId参数
    queryObj = bookStoreFuns.getHiddenInputParams(queryObj);
    // 添加promotionPosition参数
    queryObj.promotionPosition = 'kns-pic-bottom';
    try {
        $.ajax({
            url: adReqUrl,
            type: "GET",
            dataType: "json",
            data: queryObj,
            success: function (resdata) {
              console.log(resdata);
              if(resdata && resdata.code && resdata.code != "200" && resdata.data && resdata.data.length == 0) {
                  $(bookStoreData.hotIdName).hide();
                  return false;
              }
              let list=resdata.data.length>5?resdata.data.slice(0,5):resdata.data;

              let htmlStr = `<div class="books">`;
              for(var i=0;i<list.length;i++){
                // 使用接口返回的recommendFrom，如果不存在则使用默认值
                const recommendFromValue = list[i].recommendFrom || 'hot-books';
                htmlStr+=` <a href="${bookStoreData.bookHref+list[i].id}&recommendFrom=${recommendFromValue}&promotionPosition=kns-pic-bottom${list[i].recID ? '&recID='+list[i].recID : ''}" target="_blank" rel="noopener noreferrer" class="book">
                        <div class="img_box">
                          <img
                            src="${list[i].coverImage}"
                            alt="" srcset="">
                        </div>
                        <div class="text">
                          <p class="title p-ellipsis-2" title="${list[i].title}">${list[i].title}</p>
                          <p class="subtitle p-ellipsis" title="${list[i].publisher}">${list[i].publisher}</p>
                        </div>
                      </a>`;
              }
              htmlStr+=`</div>`;
              //渲染
              $(bookStoreData.hotIdName).append(htmlStr);

            },
            error: function (XMLHttpRequest, textStatus, errorThrown) {
                bookStoreFuns.consoleAd(XMLHttpRequest.status + XMLHttpRequest.statusText + " " + XMLHttpRequest.readyState + " " + textStatus);
                $(bookStoreData.hotIdName).hide();
            }
        });
    }
    catch (e) {
      console.log('catch',e);
    }
  },
  requestRelatedList: function(query) {
    console.log('requestRelatedList-请求数据');
    var adReqUrl = bookStoreData.baseUrl+'/bookstore-shop/zongku-recommend/related-books';
    let queryObj={};
    if(query == null || query == ""){
      queryObj={};
    }else{
      queryObj=query;
    }
    // 从隐藏input中读取fileId和productId参数
    queryObj = bookStoreFuns.getHiddenInputParams(queryObj);
    // 添加promotionPosition参数
    queryObj.promotionPosition = 'kns-text-bottom';
    try {
        $.ajax({
            url: adReqUrl,
            type: "GET",
            dataType: "json",
            data: queryObj,
            success: function (resdata) {
                console.log(resdata);
                if(resdata && resdata.code && resdata.code != "200" && resdata.data && resdata.data.length == 0) {
                    $(bookStoreData.relatedIdName).hide();
                    return false;
                }
                let list=resdata.data;

                //渲染元素
                if(list.length<=0||!list){
                 return false;
                }
                 let contentHtml=``;
                 contentHtml+= `<div class="book_title"><span><b>相关图书推荐</b></span></div>`;
                 let listHtml = `<div class="lists">`;
                 for(var i=0;i<list.length;i++){
                    // 使用接口返回的recommendFrom，如果不存在则使用默认值
                    const recommendFromValue = list[i].recommendFrom || 'related-books';
                    let itemHtml = ` <div class="list_item">
                    [${i+1}] <a target="_blank" title="${list[i].title}" href="${bookStoreData.bookHref+list[i].id}&recommendFrom=${recommendFromValue}&promotionPosition=kns-text-bottom${list[i].recID ? '&recID='+list[i].recID : ''}">${list[i].title}</a>. ${list[i].author?list[i].author+'. ':''}
                    ${list[i].publisher?list[i].publisher:''}
                    <span style="display: inline-block;vertical-align: middle;box-sizing: border-box;width: 20px;height: 20px;text-align: center;line-height: 18px;font-size: 12px;color: #FF9812;border: 1px solid #FF9812;border-radius: 4px;">纸</span>
                    <input class="exportparams" type="hidden" >
                  </div>`;
                  listHtml+=itemHtml;
                }
                 listHtml+=`</div>`;
                 contentHtml+=listHtml;
                 //渲染
                 $(bookStoreData.relatedIdName).append(contentHtml);
            },
            error: function (XMLHttpRequest, textStatus, errorThrown) {
                bookStoreFuns.consoleAd(XMLHttpRequest.status + XMLHttpRequest.statusText + " " + XMLHttpRequest.readyState + " " + textStatus);
                $(bookStoreData.relatedIdName).hide();
            }
        });
    }
    catch (e) {
      console.log('catch',e);
    }
  },
  consoleAd: function(val) {
    if (console.log) {
      console.log(":" + val);
    }
  }
};

// 定义调整书籍显示数量的函数
function adjustBookCount() {
  const hotBooksWidth = $(bookStoreData.hotIdName).width();
  const books = $(bookStoreData.hotIdName+' .book');
  if (hotBooksWidth <= 1000) {
    // 宽度小于等于 1000px 时，显示 4 个，隐藏第 5 个及之后的元素
    books.css('width', 'calc((100% - 3 * 10px) / 4)');
    // 从第 5 个元素开始（索引为 4）隐藏
    books.slice(4).hide();
  } else {
    // 宽度大于 1000px 时，显示 5 个，显示所有元素
    books.css('width', 'calc((100% - 4 * 10px) / 5)');
    books.show();
  }
}

//轮播图推荐图书数据加载 - 规范图片比例
$(window).on('load', function() {
  const $bookList = $('#booklist');
  if (!$bookList.length) { 
    console.log('未检测到 id="booklist" 元素，终止数据加载');
    return;
  }
  // 追加轮播样式到head
  $(bookStoreData.carouselCss).appendTo('head');

  var code = bookStoreFuns.GetScriptSrcQueryString(bookStoreData.fileName+"?", "code");
  var keyword = bookStoreFuns.GetScriptSrcQueryString(bookStoreData.fileName+"?", "keyword");
  var subject = bookStoreFuns.GetScriptSrcQueryString(bookStoreData.fileName+"?", "subject");
  let queryObj={code,keyword,subject};
  // 从隐藏input中读取fileId和productId参数
  queryObj = bookStoreFuns.getHiddenInputParams(queryObj);
  // 添加promotionPosition参数
  queryObj.promotionPosition = 'kns-pic-right';
  
  $.ajax({
    url: bookStoreData.baseUrl+'/bookstore-shop/zongku-recommend/related-books',
    type: "GET",
    dataType: "json",
    data: queryObj,
    success: function(resdata) {
      if(resdata && resdata.code && resdata.code != "200" || !resdata.data || resdata.data.length == 0) {
        $bookList.hide();
        return false;
      }

      // 1. 取消只截取2条数据，使用全部数据
      const bookList = resdata.data;
      // 2. 计算总页数（每页2条）
      const pageSize = 2;
      const totalPages = Math.ceil(bookList.length / pageSize);
      if (totalPages === 0) {
        $bookList.hide();
        return;
      }

      // 3. 构建轮播核心结构（无缝滚动：末尾复制第一页内容）
      let carouselHtml = `
      <button class="carousel-btn prev-btn"><img style="margin-left:-1px;" src="data:image/png;base64," alt="上一页"></button>
      <div class="booklist-con">
        <div class="carousel-track">
      `;
      // 4. 按页拆分数据，生成每页的内容
      for (let page = 0; page < totalPages; page++) {
        const pageBooks = bookList.slice(page * pageSize, (page + 1) * pageSize);
        let pageHtml = `<div class="carousel-page">
          <div class="books">`;
        pageBooks.forEach(book => {
          // 使用接口返回的recommendFrom，如果不存在则使用默认值
          const recommendFromValue = book.recommendFrom || 'related-books';
          pageHtml += `
            <a href="${bookStoreData.bookHref+book.id}&recommendFrom=${recommendFromValue}&promotionPosition=kns-pic-right${book.recID ? '&recID='+book.recID : ''}" target="_blank" rel="noopener noreferrer" class="book">
              <div class="img_box">
                <img src="${book.coverImage}" alt="${book.title}" srcset="">
              </div>
              <p class="title" title="${book.title}">${book.title}</p>
            </a>
          `;
        });
        pageHtml += `</div></div>`;
        carouselHtml += pageHtml;
      }
      // 关键：无缝滚动 - 复制第一页内容到轨道末尾
      const firstPageBooks = bookList.slice(0, pageSize);
      let firstPageCopyHtml = `<div class="carousel-page">
        <div class="books">`;
      firstPageBooks.forEach(book => {
        // 使用接口返回的recommendFrom，如果不存在则使用默认值
        const recommendFromValue = book.recommendFrom || 'related-books';
        firstPageCopyHtml += `
          <a href="${bookStoreData.bookHref+book.id}&recommendFrom=${recommendFromValue}&promotionPosition=kns-pic-right${book.recID ? '&recID='+book.recID : ''}" target="_blank" rel="noopener noreferrer" class="book">
            <div class="img_box">
              <img src="${book.coverImage}" alt="${book.title}" srcset="">
            </div>
            <p class="title" title="${book.title}">${book.title}</p>
          </a>
        `;
      });
      firstPageCopyHtml += `</div></div>`;
      carouselHtml += firstPageCopyHtml;

      // 5. 闭合轮播轨道，移除分页圆点HTML结构
      carouselHtml += `
        </div>
        </div>
        <button class="carousel-btn next-btn"><img src="data:image/png;base64," alt="下一页"></button>
      `;
      // 6. 渲染轮播结构到页面
      $bookList.html(carouselHtml);

      // 7. 初始化轮播逻辑
      let currentPage = 0; // 当前页码（仅对应真实页数）
      const $track = $('.carousel-track');
      const $prevBtn = $('.prev-btn');
      const $nextBtn = $('.next-btn');
      let autoPlayTimer;
      let isTransitioning = false; // 标记是否正在过渡，防止快速点击

      // 切换页面的核心方法（优化无缝滚动）
      function switchPage(targetPage, isManual = false) {
        // 防止过渡中重复触发
        if (isTransitioning) return;
        isTransitioning = true;

        // 处理下一页无缝滚动：最后一页 → 复制的第一页 → 瞬间切回真实第一页
        if (targetPage >= totalPages) {
          // 先滑到复制的第一页（视觉上是平滑的）
          $track.css('transform', `translateX(-${totalPages * 100}%)`);
          // 过渡完成后，瞬间切回真实第一页（无过渡动画）
          setTimeout(() => {
            $track.css({
              'transition': 'none',
              'transform': 'translateX(0%)'
            });
            currentPage = 0;
            // 恢复过渡动画
            setTimeout(() => {
              $track.css('transition', 'transform 0.5s ease-in-out');
              isTransitioning = false;
            }, 50);
          }, 500); // 与CSS过渡时长一致
        } 
        // 处理上一页无缝滚动：第一页 → 瞬间切到复制的最后一页 → 滑到真实最后一页
        else if (targetPage < 0) {
          // 先瞬间切到复制的最后一页（无过渡）
          $track.css({
            'transition': 'none',
            'transform': `translateX(-${totalPages * 100}%)`
          });
          // 强制重绘后恢复过渡，滑到真实最后一页
          setTimeout(() => {
            $track.css({
              'transition': 'transform 0.5s ease-in-out',
              'transform': `translateX(-${(totalPages - 1) * 100}%)`
            });
            currentPage = totalPages - 1;
            setTimeout(() => {
              isTransitioning = false;
            }, 500);
          }, 50);
        } 
        // 正常页面切换
        else {
          const offset = -targetPage * 100;
          $track.css('transform', `translateX(${offset}%)`);
          currentPage = targetPage;
          setTimeout(() => {
            isTransitioning = false;
          }, 500);
        }
      }

      // 8. 自动轮播逻辑（优化间隔，避免过快）
      function startAutoPlay() {
        autoPlayTimer = setInterval(() => {
          switchPage(currentPage + 1);
        }, 4000); // 延长自动轮播间隔到4秒，更舒适
      }
      startAutoPlay();

      // 9. 鼠标悬停时暂停自动轮播，离开后恢复
      $bookList.hover(
        () => clearInterval(autoPlayTimer),
        () => startAutoPlay()
      );

      // 10. 点击下一页按钮
      $nextBtn.click(() => {
        switchPage(currentPage + 1, true);
      });

      // 11. 点击上一页按钮
      $prevBtn.click(() => {
        switchPage(currentPage - 1, true);
      });

    },
    error:  function (XMLHttpRequest, textStatus, errorThrown) {
      bookStoreFuns.consoleAd(XMLHttpRequest.status + XMLHttpRequest.statusText + " " + XMLHttpRequest.readyState + " " + textStatus);
      $bookList.hide();
    }
  });
});
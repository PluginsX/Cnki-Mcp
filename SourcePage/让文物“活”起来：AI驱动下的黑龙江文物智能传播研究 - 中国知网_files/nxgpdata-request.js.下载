    lazyLoadObj.prototype.Funcs = {
        scrollHandler: function (){
            if ($lazyLoadObj.Data.refPartTabs === "references") {
                if ($lazyLoadObj.Data.lazyLoadArr1.length == $lazyLoadObj.Data.lazyLoadArr.length) {
                    window.removeEventListener("scroll", this.scrollHandler);
                    window.removeEventListener("resize", this.scrollHandler);
                    $lazyLoadObj.Data.flag = false;
                }
                $lazyLoadObj.Funcs.scrollHandlerArr($lazyLoadObj.Data.lazyLoadArr, $lazyLoadObj.Data.lazyLoadArr1);
            } else {
                if ($lazyLoadObj.Data.refPartCheckArr1.length == $lazyLoadObj.Data.refPartCheckArr.length) {
                    window.removeEventListener("scroll",this.scrollHandler);
                    window.removeEventListener("resize", this.scrollHandler);
                    $lazyLoadObj.Data.flag = false;
                }
                $lazyLoadObj.Funcs.scrollHandlerArr($lazyLoadObj.Data.refPartCheckArr, $lazyLoadObj.Data.refPartCheckArr1);
            }
        },
        // 滚动调用公共循环的方法
        scrollHandlerArr:function(arr, arr1) {
            for (var i = 0; i < arr.length; i++) {
                if (arr[i].isShow && !arr[i].isRequest && $("#" + arr[i].id).length > 0){
                    var el = $("#" + arr[i].id)[0];
                    var topRect = el.getBoundingClientRect();
                    var h = document.documentElement.clientHeight || document.body.clientHeight;
                    if (topRect.top < h) {
                        $lazyLoadObj.Funcs.funCommon(i,arr);
                        arr1.push(arr[i]);
                    }
                }
            }
        },
        funCommon: function(i,arr){
            arr[i].isRequest = true;
            // loadCondition(i);
            var dtd = $.Deferred();  // 新建一个Deferred对象
            var wait = function (dtd) {
                var task = function () {
                    // 执行的方法
                    /*eval(func);*/
                    if(arr[i].fun == "getSimilarDataFromApi"){
                        eval(arr[i].fun + "("+arr[i].param+")");
                    }else {
                        eval(arr[i].fun + "("+arr[i].param+",dtd)");
                    }

                };
                task();
                return dtd;
            };
            $.when(wait(dtd))
                .done(function () {
                    $lazyLoadObj.Funcs.loadCondition(i,arr);
                })
                .fail(function () {
                    $lazyLoadObj.Funcs.loadCondition(i,arr);
                });
        },

        // 点击跳转方法  将他之前所有的没执行的都请求一遍
        funCommonTab: function (index) {
            $lazyLoadObj.Data.funCommonTabCnt = 0
            $lazyLoadObj.Data.funCommonTabNum = 0
            $lazyLoadObj.Data.funCommonTabNum1 = 0

            var lazyLoadArr = $lazyLoadObj.Data.lazyLoadArr
            for (var i = 0; i < lazyLoadArr.length; i++) {
                if (lazyLoadArr[i].tabIndex <= index) {
                    if (!lazyLoadArr[i].isRequest) {
                        lazyLoadArr[i].isRequest = true
                        lazyLoadArr[i].isShow = true
                        $("#" + lazyLoadArr[i].id).addClass("dis-show").removeClass("dis-none");
                        $lazyLoadObj.Data.funCommonTabNum++
                        if (i == 0) {
                            eval(lazyLoadArr[i].fun + "(" + lazyLoadArr[i].param + ",false,isTab=1)");
                        }else{
                            eval(lazyLoadArr[i].fun + "(" + lazyLoadArr[i].param + ",'',false,isTab=1)");
                        }
                    } else {
                        $lazyLoadObj.Data.funCommonTabNum1++
                    }
                } else {
                    //点击按钮的下一个 且不是最后一个，且没有请求过
                    if (lazyLoadArr[i].tabIndex == (index + 1) && lazyLoadArr[i].sort == 0 && !lazyLoadArr[i].isRequest) {
                        // 他的下一个也要显示
                        $("#" + lazyLoadArr[i].id).addClass("dis-show").removeClass("dis-none");
                        lazyLoadArr[i].isShow = true;
                    }
                    $lazyLoadObj.Data.funCommonTabNum1++
                }

                if ($lazyLoadObj.Data.funCommonTabNum1 == lazyLoadArr.length) {
                    $lazyLoadObj.Funcs.tabCallback(0)
                }

            }
        },
        tabCallback: function (num) {
            // 当走请求的时候++ 不走请求了直接为0
            if (num != 0) {
                $lazyLoadObj.Data.funCommonTabCnt++;
            }
            if ($lazyLoadObj.Data.funCommonTabNum == $lazyLoadObj.Data.funCommonTabCnt + 2 || num == 0) {
                $("body,html").animate(
                    { scrollTop: $("#literature-recommend").offset().top },
                    500
                );
            }
        },
        // 公共方法
        loadCondition: function(i,arr) {
            if (arr.length == i + 1) return;
            $("#" + arr[i + 1].id).addClass("dis-show").removeClass("dis-none");
            arr[i + 1].isShow = true;
            $lazyLoadObj.Funcs.scrollHandler();
        },
        // 节流
        throttleDebounce: function(fn, delay, mustRunDelay) {
        var timer = null;
        var t_start;
        return function () {
            var context = this;
            var args = arguments;
            var t_curr = +new Date();

            clearTimeout(timer);
            if (!t_start) {
                t_start = t_curr;
            }
            if (mustRunDelay != 0 && t_curr - t_start >= mustRunDelay) {
                fn.apply(context, args);
                t_start = t_curr;
            } else {
                timer = setTimeout(function () {
                    fn.apply(context, args);
                }, delay);
            }
        };
    }
    }
    $lazyLoadObj = $.extend({}, new lazyLoadObj);
})();

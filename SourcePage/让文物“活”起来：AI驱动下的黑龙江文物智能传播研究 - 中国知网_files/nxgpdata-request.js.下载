//AI问题
function aiQuestion(){

    var title  = $(".wx-tit h1").clone().find('span').remove().end().text().trim();
    var abstarct = $("#abstract_text").length >0 ? $("#abstract_text").val().trim() : $(".abstract-text").text().trim();
    if(!abstarct){
        abstarct = title;
    }
    var keywords = $(".keywords").length >0 ? $(".keywords").text().trim():title;
    var id = $("#export-id").val();
    var type="PDF";
    var fileType =$("#filetype").length >0 ? $("#filetype").val():"";
    if(fileType && fileType.indexOf("XML") > -1){
        type = "XML";
    }

    var apiHost =  $("#apiHost").val()
    if(apiHost.indexOf("/restapi")>0){
        apiHost = apiHost.replace("/restapi","/uniapps");
    }else{
        apiHost = apiHost+"/uniapps";
    }
    var url = apiHost + "/aggr/v1/question/single";
    var data = {
        title: title,
        content: abstarct,
        keywords: keywords,
        id:id,
        type:type
    };
    var piccachelink = $("#piccachelink").val();
    if(keywords && abstarct){
        $.ajax({
            url: url,
            type: "POST",
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (data) {
                if(data.code === 0 && data.data && data.data.length > 0){
                    var ul="<ul class=\"ai-ask-question\">";
                    var length = data.data.length;
                    if(length > 4){
                        length = 4;

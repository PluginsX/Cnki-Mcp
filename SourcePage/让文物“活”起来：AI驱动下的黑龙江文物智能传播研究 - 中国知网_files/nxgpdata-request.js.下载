                        ul +=  "<li class='"+calssName+"'><div class=\"ai-ask-border\"></div>";
                        ul += "<div class=\"ai-ask-item\">";
                        var ti = data.data[i].question;
                        var url = data.data[i].url;src='"+piccachelink+"images/basic/loading.gif'
                        ul+="<a target='_blank' href='"+url+"'><div class=\"icon-ai-box\"><img src='"+piccachelink+"images/gb/kcms8/ndetail/icon-ai.png'></div><p class='text'>"+ti+" </p></a></li>";
                    }
                    ul+="</ul>";

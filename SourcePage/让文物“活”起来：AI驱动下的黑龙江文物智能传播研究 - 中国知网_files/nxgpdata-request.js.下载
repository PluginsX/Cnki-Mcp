// 监听整个文档的DOM变化
function observeListsContainer() {
    const targetNode = document.body;
    const config = {
        childList: true,      // 监听子节点变化
        subtree: true         // 监听所有后代节点
    };

    const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            // 检查新增的节点中是否有 .lists
            mutation.addedNodes.forEach(function(node) {
                if (node.nodeType === 1) { // 元素节点
                    // 检查当前节点
                    if ($(node).hasClass('book_title')) {
                        getSimilarEbookFromApi();
                    }

                }
            });
        });
    });

    observer.observe(targetNode, config);

    // 返回observer以便后续可以取消监听
    return observer;
}
function parseDisplayCount(displayText) {
    if (String(displayText).indexOf('万')>-1) {
        const num = parseFloat(displayText);
        return Math.round(num * 10000); // 转回原始数值
    }
    return parseInt(displayText);
}

function parseDisplayCount2(displayText,type) {
    if (String(displayText).indexOf('万')>-1) {
        const num = parseFloat(displayText);
        if(isNaN(num)){
           var resultNum = localStorage.getItem(type+"-num");
           return parseDisplayCount2(resultNum);
        }
        return Math.round(num * 10000); // 转回原始数值
    }else{
        if(isNaN(displayText)){
            var resultNum = localStorage.getItem(type+"-num");
            return parseInt(resultNum);
        }else{
            return parseInt(displayText);
        }
    }

}

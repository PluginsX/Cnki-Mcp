function statisticsTotal(type){
    if (window.localStorage) {
        window.localStorage.removeItem(type+"-num");
    }
    var apiHost =  $("#tHost").val()
    var id = $("#export-id").val();
    var uniplatform = getKcmsUrlParam("uniplatform");
    if(!uniplatform || (uniplatform.toLowerCase() != "nzkpt"
        && uniplatform.toLowerCase() != "chkd")){
        uniplatform = "NZKPT";
    }
    var url = apiHost + "/ket-api/interaction/query?type="+type.toUpperCase()+"&articleId="+id+"&tenantId="+uniplatform;
    $.ajax({
        url: url,
        type: "GET",
        xhrFields: {withCredentials: false},
        contentType: "application/json",
        success: function (result) {
            if(result.code === 0 && result.data){
                var data = result.data;
                if(data.total && parseInt(data.total)>0){
                    var total = data.total;
                    if(type.toLowerCase()=="share"){
                        $(".stats-moudle .share").addClass('show');
                    }
                    total = formatNum(parseInt(total));
                    localStorage.setItem(type+"-num", total);
                    $("."+type+"-num").text(total);
                }else{
                    initLikeNum(type);
                }
            }else{
                initLikeNum(type);
            }
        },
        error: function() {
            initLikeNum(type);
        }
    });
}
function initLikeNum(type){
    if(type.toLowerCase()=="like"){
        $(".like-num").text("");
    }
}

function formatNum(num){
    if (num > 10000) {
        var wan = (parseInt(num) / 10000).toFixed(1);
        // 移除末尾的 ".0"
        return parseFloat(wan).toString()+"万";
    }else{
        return num;
    }

}
function paintingTree(arr, tree, hid) {

    if($(".tab-recommend-navi").length>0){
        $(".tab-recommend-navi").show();
        $("#kcms-data-catalog-title").show();
        $("#kcms-data-catalog-title").addClass("active")
    }
    getnewary(arr)
    function getnewary(arr) {
        for (var j = 0; j < arr.length; j++) {
            if (arr[j]["children"]) {
                arr[j].open = true;
                getnewary(arr[j]["children"])
            } else {
                return
            }
        }
    }
    var str = "";
    function createTree(arr, hid) {

        if (arr) {
            var children = arr;
            str += "<ul>";
            for (var j = 0; j < children.length; j++) {
                str += "<li>"

                if (!children[j]["id"]) {
                    return;
                }
                var temp_id = children[j]["id"];
                var temp_title = children[j]["title"];
                var tempurl = children[j]["relations"][0]["url"];

                var tiaomu_xz = `<span class='actived'> <a class='highco' id='${temp_id}' href='${tempurl}'  title='${temp_title}' target='blank' >${temp_title}</a></span>`;
                var tiaomu = `<span class="actived"> <a  id='${temp_id}' href='${tempurl}'  title='${temp_title}' target='blank' >${temp_title}</a></span>`;

                if (children[j]["children"]) {

                    if (children[j]["open"]) {
                        if (temp_id.toLowerCase() == hid.toLowerCase()) {
                            str += "<div class='tree-item' open='true'><span class='close' onclick=openclosetree(this)></span>" + tiaomu_xz+"</div>";
                        }
                        else {
                            str += "<div class='tree-item' open='true'><span class='close' onclick=openclosetree(this)></span>" + tiaomu+"</div>";
                        }
                    }
                    else {
                        if (temp_id.toLowerCase() == hid.toLowerCase()) {
                            str += "<div class='tree-item' open='false'><span class='open' onclick=openclosetree(this)></span>" + tiaomu_xz+"</div>";
                        }
                        else {
                            str += "<div class='tree-item' open='false'><span class='open' onclick=openclosetree(this)></span>" + tiaomu+"</div>";
                        }
                    }
                } else {
                    if (temp_id.toLowerCase() == hid.toLowerCase()) {
                        str += "<div class='tree-item'><span class='lf'></span>" + tiaomu_xz+"</div>";
                    } else {
                        str += "<div  class='tree-item'><span class='lf'></span>" + tiaomu+"</div>";
                    }
                }
                createTree(children[j]["children"], hid)
                str += "</li>"
            }
            str += "</ul>";
        }

    }
    createTree(arr, hid);
    if (str.length > 0 && $("#kcms-data-catalog-title").length==0) {
        str = "<h5>栏目目录</h5>" + str;
    }
    $("#" + tree).html(str);
    $("[open=true]").each(function () {
        $(this).next().show();
    })
    $("[open=false]").each(function () {
        $(this).next().hide();
    })
}
function openclosetree(o) {
    if ($(o).hasClass("open")) {
        $(o).parent().next().show();
        $(o).addClass("close").removeClass("open");
    }
    else {
        $(o).parent().next().hide();
        $(o).addClass("open").removeClass("close");
    }
}


            enterable: true,
            textStyle: {
                whiteSpace: 'pre-line', // 使用pre-line保留换行符
                wordBreak: 'break-all'
            },
            formatter: function (params) {
                var name = params.data.name;
                if(name){
                    // 获取字符串的最后一个字符
                    var lastChar = name.charAt(name.length - 1);
                    // 判断这个字符是否是分号或逗号
                    if(lastChar === ';' || lastChar === ',' || lastChar === '；' || lastChar === '，'){
                        name = name.slice(0,-1);
                    }
                }

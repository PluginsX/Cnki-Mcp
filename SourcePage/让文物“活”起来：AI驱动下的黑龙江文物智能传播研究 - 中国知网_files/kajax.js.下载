                var div = $("#yyThemeWords");
                var ul = "<ul id='keyword'><li class='top-space'><span class='rowtit'>MESH TERMS：</span><p></p></li></ul>"
                div.append(ul);
                var content = "";
                var appPath = $("#appPath").val();
                for (var m = 0; m < map.length; m++) {
                    content += "<a target='_blank' href='../mci/detail?"+map[m].LINK+"'>"+map[m].TITLE +";</a>";
                }
                $("#yyThemeWords #keyword p").append(content);
            }
        });
    }

}

// 反转义HTML函数
function unescapeHtml(text) {
    return text.replace(/&amp;|&lt;|&gt;|&quot;|&#39;/g, function(match) {
        return {
            '&amp;': '&',
            '&lt;': '<',
            '&gt;': '>',
            '&quot;': '"',
            '&#39;': "'"
        }[match];
    });
}


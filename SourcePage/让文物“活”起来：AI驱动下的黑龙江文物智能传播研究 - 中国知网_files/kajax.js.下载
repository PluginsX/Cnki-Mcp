                        if(content && content.length > 34){
                            // 圆环最内层属于长度大于4个时截取前4位展示，鼠标浮上去显示完整
                            return  content.substring(0, 34) + '...';
                        }else{
                            return  content;
                        }
                    },
                },
                leaves: {
                    label: {
                        position: 'right',
                        verticalAlign: 'middle',
                        align: 'left'
                    }
                },
                /*label: {
                    show: 'false',
                    distance: 10
                },*/
                itemStyle: {
                    color: '#c23531'
                },
                emphasis: {
                    focus: 'descendant'
                },
                expandAndCollapse: true,
                animationDuration: 550,
                animationDurationUpdate: 750
            }
        ]
    };

    myChart.setOption(option);

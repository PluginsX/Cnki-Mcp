/**
 * 生成密钥
 * @param {string} password 加密密钥
 * @returns {CryptoJS.lib.WordArray} 密钥
 */
function generateKey(password) {
    return CryptoJS.enc.Utf8.parse(password);
}


/**
 * DES加密字符串
 * @param {string} data 待加密字符串
 * @returns {string} 加密后内容（Base64 URL 编码）
 */
function encryptByDES(data) {
    // 偏移变量，固定占8位字节
    const KEY_IV = CryptoJS.lib.WordArray.create([0x16, 0x34, 0x56, 0x58, 0x88, 0xAB, 0xCD, 0xEF]);
    // 默认加密解密密钥
    const PASSWORD = "CNKIKCMS";
    if (!data) {
        throw new Error("DES-encrypt：加密参数集不能为空");
    }
    // 生成密钥
    const secretKey = generateKey(PASSWORD);

    // 加密
    const encrypted = CryptoJS.DES.encrypt(data, secretKey, {
        iv: KEY_IV,
        mode: CryptoJS.mode.CBC,
        padding: CryptoJS.pad.Pkcs7
    });

    // 获取加密后的 Base64 字符串
    const base64String = encrypted.toString();

    // 转换为 Base64 URL 编码
    const base64UrlString = base64String
        .replace(/\+/g, '-') // 替换 '+' 为 '-'
        .replace(/\//g, '_') // 替换 '/' 为 '_'
        .replace(/=+$/, ''); // 删除末尾的 '='

    return base64UrlString;
}

function byteToString(arr) {
    if (typeof arr === 'string') {
        return arr;
    }
    var str = '', _arr = arr;
    for (var i = 0; i < _arr.length; i++) {
        var one = _arr[i].toString(2),
            v = one.match(/^1+?(?=0)/);
        if (v && one.length == 8) {
            var bytesLength = v[0].length;
            var store = _arr[i].toString(2).slice(7 - bytesLength);
            for (var st = 1; st < bytesLength; st++) {
                store += _arr[st + i].toString(2).slice(2);
            }
            str += String.fromCharCode(parseInt(store, 2));
            i += bytesLength - 1;
        } else {
            str += String.fromCharCode(_arr[i]);
        }
    }
    return str;
}


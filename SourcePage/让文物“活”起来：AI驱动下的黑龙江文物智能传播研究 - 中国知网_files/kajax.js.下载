function getWwMciKeyword(suc,enZtc,urlFormat){
    if(suc && suc.split(";;").length > 0){
        var mainCodes = suc.split(";;");
        var strMainCodes =  mainCodes.join(",");
        enZtc = unescapeHtml(enZtc);
        var ztcs = enZtc.replace(/;;;;/g,";;").split(";;");
        var url = urlFormat.format(strMainCodes);
        $.get(url, function (result) {
            if (result.data && result.data.length > 0) {
                var list = result.data;
                var map=[];
                for (var i = 0; i < ztcs.length; i++) {
                    for (var j = 0; j < list.length; j++) {

            recommended = 1
        }

    }
    var url = apiHost + "/journalmarket/v2/push/single?id="+id+"&position="+tag+"&autolgo="+autolog+"&recommended="+recommended;
    $.ajax({
        url: url,
        type: "GET",
        contentType: 'application/json',
        timeout: 5000,
        headers: getHearder("JZTJ"),
        success: function (data) {
            if(data.code === 0 && data.data && data.data.pushState ===1){
                var result = data.data;
                var person = result.rcmPerson;
                var personTitle = result.rcmPersonTitle;
                var comment = result.rcmComment;
                var content = "";
                /*content += "<li class=\"btn-editor-content\">";
                    content +=  "<span class='editor-name'><i></i>主编荐语</span>";*/
                        content += "<span class=\"cate-box\"></span>";
                        content +="<div onclick=\"event.stopPropagation()\">";
                            content += "<div class='editor-name'><i></i><div>主编荐语</div></div>";
                            content +=  "<div class=\"editor-detail\">";
                            if(person){
                                content +=  "<div class='editor-author'>"+person+"</div>";
                            }
                            if(personTitle){
                                content +=  "<div class='editor-title'>（"+personTitle+"）：</div>";
                            }
                            if(comment){
                                content +=  "<div class='editor-comment'>"+comment+"</div>";
                            }

                            content +="</div>";
                        content +="</div>";
               /* content += "</li>"*/

                $(".other-btns .btn-recommend").append(content);
				$(".other-btns .btn-recommend").removeAttr("title");
                $(".wx-tit h1").append("<span class=\"editor-span\">主编推荐</span>")
            }
        },
        error: function(xhr, status, error) {
            if (status === 'timeout') {}
        }
    });
}



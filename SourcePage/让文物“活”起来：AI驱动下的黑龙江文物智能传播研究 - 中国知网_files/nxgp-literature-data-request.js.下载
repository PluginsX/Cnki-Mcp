                        hanlderVideoFrame(ID,vfn,fn,date,fbl,yltsl,unplatform,type);
                    }else{
                        $("#video-mask").show();
                    }
                }

            }else{
                if(name && href){
                    html +="<li><a target=\"_blank\" href='"+href+"' >"+(i+1)+"、"+name+"</a></li>";
                }else if(name && !href){
                    html +="<li>"+(i+1)+"、"+name+"</li>";

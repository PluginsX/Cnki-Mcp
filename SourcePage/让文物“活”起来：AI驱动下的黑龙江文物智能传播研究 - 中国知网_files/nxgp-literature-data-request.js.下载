function renderProcess(data,pubtype){
    if (!nxgpdata_stucture_check_datalist(data)) {
        return "";
    }
    var processType="";
    switch (pubtype) {
        case "2":
            processType = "DPYX";
            break;
        case "3":
            processType = "ZQYX";
            break;
        case "7":
            processType = "LYDG";
            break;
        case "8":
            processType = "PBDG";
            break;
        case "9":
            processType = "ZQDG";
            break;
        default:
            processType = "YSB";
            break;
    }
    var process = data.data.processes;

    var div = "<ul class=\"sort-list\">";
    if(process.length>0){
        for (var i = 0; i < process.length; i++) {
            var relations = process[i].relations;
            var name = process[i].process;
            if(relations){
                if(processType == name){
                    $("#curname").html(message[name.toUpperCase()]);
                }
                var href = urlByScope(relations, "ABSTRACT");
                div +="<li ><a target='_self' href='"+href+"'>"+message[name.toUpperCase()]+"</a></li>"
            }
        }
    }
    div += "</ul>";
    return div;
}



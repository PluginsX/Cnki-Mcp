function userHitLog(obj,position){
    var param = $(obj).attr("id");
    var strs = param.split("|");
    var recId = strs[0] ? strs[0]:"";
    var filename = strs[1]? strs[1]:"";
    var title =$(obj).text();
    var userip = getClientIP();
    if(userip && userip.indexOf("%7C") > -1){
        userip = userip.split("%7C")[0];
    }
    var clientid = getClientID();
    if(clientid && clientid.indexOf("%7C") > -1){
        clientid = clientid.split("%7C")[0];
    }
    var c_m_LinID = newgetCookie("c_m_LinID");
    if(c_m_LinID){
        var e = c_m_LinID.indexOf("="),
            i = c_m_LinID.lastIndexOf("&");
        var indenId = c_m_LinID.substring(e + 1, i);
    }

    if(!indenId){indenId = -1;}
    var params = 'idenID='+ indenId + '&clientID=' + clientid + '&userIP=' + userip + '&platformURL='+position+'&recID='+recId+'&resourceType=paper&resourceID='+filename+'&resourceName='+ title;
    $.ajax({
        url: 'https://recsys.cnki.net/RCDService/api/Log/UserHitLog?' + params,
        type: "POST",
        /* data: JSON.stringify(kdata),*/
        /*  headers: getHearder(),*/
        dataType: "json",
        contentType: "application/json",
        success: function (data) {
            if (!data || !data.Success) {
                console.log("日志记录失败！")
            }
        }
    });

}


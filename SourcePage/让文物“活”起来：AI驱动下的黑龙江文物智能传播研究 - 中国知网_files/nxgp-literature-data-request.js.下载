function getSimilarEbookFromApi(){
    var v = $("#paramkcmslink").val();
    if(!v){
        return;
    }
    var url = "../book/recommend?{0}";
    url = url.format(v);
    $.get(url, function (data) {
        let html = '';
        if (data &&  data.length > 0) {
            /*var ulhtml = urpart_content(data,"EBOOK",1,"");*/
            var $lists = $('#relBooks .lists')
            var $existingItems = $lists.find('.list_item');
            // 如果已经处理过，不再重复处理
            if ($lists.data('merged')) {
                return;
            }
            // 1. 先移除他们的后5条数据
            var $theirLast5 = $existingItems.slice(5);// 获取他们的后5条
            $theirLast5.detach();// 先移除但保留引用
            // 2. 清空现有内容
            $lists.empty();
            // 3. 插入我的5条数据
            for (var i = 0; i < data.length; i++) {
                var dataarrdata = data[i];
                var newIndex = i + 1;
                const $newItem = createBookItem(dataarrdata, newIndex);
                $lists.append($newItem);

            }
            // 4. 插入他们的前5条数据（重新编号）
            $existingItems.slice(0, 5).each(function(index) {
                const $item = $(this);
                const newIndex = index + 6; // 6-10
                updateBookItemNumber($item, newIndex);
                $lists.append($item);
            });

            // 标记已处理
            $lists.data('merged', true);

            console.log('数据合并完成');

            // 触发自定义事件
            $(document).trigger('books:merged');

        }
    });
}

function createBookItem(dataarrdata, index) {

    var ti = _findmetadatavalue(dataarrdata, "TI");
    var link = _findrelationsvalue(dataarrdata, "ABSTRACT");
    var author = _findmetadatavalue(dataarrdata, "AU");
    var ptitle = dataarrdata.source.title? dataarrdata.source.title : "";

    return $(`
            <div class="list_item">
                [${index}] <a target="_blank" title="${ti}" href="${link}">${ti}</a>. ${author}. ${ptitle}
            </div>
        `);
}
// 更新现有图书条目的序号
function updateBookItemNumber($item, newIndex) {
    // 获取原始的HTML内容
    let html = $item.html();

    // 替换序号部分
    // 匹配 [数字] 开头的部分
    html = html.replace(/\[\s*(\d+)\s*\]/i,  `[${newIndex}]`);

    // 更新HTML
    $item.html(html);

    return $item;
}
function handlZbtjSignSort(){

    $("#kcms-data-reader-recommend li").each(function (index) {
        if($(this).find(".editor-span").length > 0){
            var index = $(this).index();
            if(index != 0){
                $(this).prependTo("#kcms-data-reader-recommend .ebBd");
                resetItemNumbers("kcms-data-reader-recommend");
            }
        }
    })

    $("#kcms-data-similar li").each(function (index) {
        if($(this).find(".editor-span").length > 0){
            var index = $(this).index();
            if(index != 0){
                $(this).prependTo("#kcms-data-similar .ebBd");
                resetItemNumbers("kcms-data-similar");
            }
        }
    })
}
function addZbtjSignList(div,kdata,positionDiv){

    var apiHost =  $("#apiHost").val()
    if(apiHost.indexOf("/restapi")>0){
        apiHost = apiHost.replace("/restapi","/uniapps");
    }
    var url = apiHost + "/journalmarket/v2/push/list";
    if(kdata.ids && kdata.ids.length > 0){
        $.ajax({
            url: url,
            type: "POST",
            contentType: 'application/json',
            data: JSON.stringify(kdata),
            headers: getHearder("JZTJ"),
            timeout: 8000,
            success: function (data) {
                if(data.code === 0 && data.data && data.data.length > 0){
                    var result = data.data;
                    for (var i = 0; i < result.length; i++) {
                        if(result[i].pushState === 1){
                            var tjId = result[i].fileId;
                            $("#"+div+" li #"+tjId).after("<span class=\"editor-span\" >主编推荐</span>")
                            var index = $("#"+div+" #"+tjId).parent("li").index()
                            if(index === 0){
                                continue;
                            }
                            if(positionDiv){
                                var $fifthItem = $("#"+div+" ."+positionDiv+" li").eq(i);
                                $fifthItem.prependTo("#"+div+" ."+positionDiv);
                                $("#"+div+" ."+positionDiv+" li").each(function(index) {
                                    // 序号从1开始
                                    $(this).find('.number').text("["+(index + 1)+"]");
                                });
                            }else{
                                var $fifthItem = $("#"+div+" li").eq(i);
                                $fifthItem.prependTo("#"+div+" .ebBd");
                                resetItemNumbers(div);
                            }

                        }
                    }

                }
            },
            error: function(xhr, status, error) {
                if (status === 'timeout') {}
            }
        });
    }
}


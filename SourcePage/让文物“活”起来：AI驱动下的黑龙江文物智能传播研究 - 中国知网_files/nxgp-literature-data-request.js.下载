    var json = {
        Resource: "",
        Classid: type,
        Products: "",
        QNode: {
            QGroup: [
                {
                    Key: "subject",
                    Title: "",
                    Logic: 0,
                    Items: [
                        {
                            Field: field,
                            Value: id,
                            Operator: "DEFAULT",
                            Logic: 0
                        }
                    ],
                    ChildItems: []
                }
            ]
        },
        ExScope: 1,
        SearchType: 2,

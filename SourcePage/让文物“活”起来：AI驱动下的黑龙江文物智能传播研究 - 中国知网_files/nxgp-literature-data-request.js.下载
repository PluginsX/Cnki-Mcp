            $.get(url,function(data){
                var base64String = data.data ? data.data:"";
                var video = new Array();
                if(base64String && !base64String.msg){
                    // 解码Base64并处理UTF-8
                    var decodedString = decodeURIComponent(escape(atob(base64String)));
                    decodedString = JSON.parse(decodedString);
                    var playlist = decodedString.url;
                    playlist  = JSON.parse(playlist);
                    for (var k in playlist) {
                        var item = new Array();
                        item.push(playlist[k]);
                        item.push('video/m3u8');
                        item.push(k);
                        item.push(0);
                        video.push(item);
                    }

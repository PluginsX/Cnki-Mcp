//大陆法规效力级别分组
function getRelatedLawLevelLegal(div,filename,product){

    if($(".keywords").length > 0 && $(".keywords").find("a").length>0){
        var keyword =  $(".keywords").find("a").text();
        var arrKeyword = keyword.split(";");
        var filteredArr = arrKeyword.filter(function(value) {
            return value !== null && value !== undefined && value !== "";
        });
        var data = {
            filteredArr: filteredArr,  // 必须是数组，不能是对象
            filename: filename,
            product: product
        };
        $.ajax({
            url: '../law/level-legal',
            type: 'POST',
            contentType: 'application/json; charset=UTF-8',
            data: JSON.stringify(data),
            success: function(data) {
                if (data && data.length>0) {
                    var referenceOrder = [
                        '01', '0201', '0202', '0203', '0204',
                        '03', '06', '08', '05', '07',
                        '04', '09', '10', '14', '15',
                        '17', '13010301', '13010302'
                    ];
                    // 创建参考顺序的映射对象（提高查找效率）
                    var orderMap = {};
                    referenceOrder.forEach(function(code, index) {
                        orderMap[code] = index + 1; // 使用1-based索引
                    });

                    // 1. 首先过滤掉code不在参考顺序中的对象
                    var filteredList   = data.filter(function(item) {
                        return orderMap.hasOwnProperty(item.code);
                    });

                    // 2. 然后按照参考顺序排序
                    var results = filteredList.sort(function(a, b) {
                        return orderMap[a.code] - orderMap[b.code];
                    });
                    var chekcLevel = results[0].code ? results[0].code: results[0].name;
                    var ulhtml = lawLevelHtml(results,filename,product);
                    $("#" + div).html(ulhtml);
                    geLawLiteraturesByLevel(chekcLevel,filename,product);
                    $("#" + div).show();
                } else {
                    noData(div);
                }
            }
        });
    }else{
        noData(div);
    }

}


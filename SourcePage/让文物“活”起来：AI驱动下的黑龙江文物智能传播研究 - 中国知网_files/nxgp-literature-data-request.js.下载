//同栏目文献年份
function getYearbookSameColumnLiteratureYears(div, year) {
    if (!div) {
        return;
    }
    //已经有数据不再发送请求
    if ($("#" + div).length > 1) {
        return;
    }
    var chekcYear;
    var wgpart = getVV();
    var filename = $("#paramfilename").val();
    var apiHost = $("#apiHost").val() ? $("#apiHost").val() + "/literature-api" : literaturesApiHost;
    var url = apiHost + yearbookSameColumnLiteratureYearsURL.replace("{id}", filename) + wgpart;

    $("#" + div).attr("isRequest", 1);
    $.ajax({
        url: url,
        type: "POST",
        headers: getHearder(),
        dataType: "json",
        contentType: "application/json",
        success: function (data) {
            if (data.data && data.data.length > 0) {
                years = data.data.sort(function(a,b){
                    if(b.code){
                        return b.code-a.code
                    }else{
                        return b.YEAR-a.YEAR
                    }

                });

                if (!year) {
                    chekcYear = years[0].code?years[0].code: years[0].YEAR;
                }
                var ulhtml = yearbookSameColumnLiteratureYearsDataConversion(years, chekcYear);
                $("#" + div).html(ulhtml);
                getYearbookSameColumnLiteratures(chekcYear, 1);
                $("#" + div).show();
            } else {
                noData(div);
            }
        }
    });


}


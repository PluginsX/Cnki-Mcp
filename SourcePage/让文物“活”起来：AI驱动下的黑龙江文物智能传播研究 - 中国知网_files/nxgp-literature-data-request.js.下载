                    html +="<li><a class='row' target=\"_blank\" href='"+href+"' ><i class=\"icon-video\"></i>"+(i+1)+"、"+name+"</a></li>";
                }else{
                    html= "";
                }
            }

        }
    }
    html += "</ul></div>";
    return html;
}

function findMetadataValue(dataarrdata, mname) {
    if (!dataarrdata.metadata || !dataarrdata.metadata.length > 0) {
        return "";
    }
    for (i = 0; i < dataarrdata.metadata.length; i++) {
        if (!dataarrdata.metadata[i].name) {
            continue;
        }
        if (dataarrdata.metadata[i].name == mname) {
            return dataarrdata.metadata[i].value;
        }
    }
    return "";
}

function findRelationsValue (dataarrdata, mname) {
    if (!dataarrdata.relations || !dataarrdata.relations.length > 0) {
        return "";
    }
    for (i = 0; i < dataarrdata.relations.length; i++) {
        if (!dataarrdata.relations[i].scope) {
            continue;
        }
        if (dataarrdata.relations[i].scope == mname) {
            return dataarrdata.relations[i].url;
        }
    }
    return "";
}



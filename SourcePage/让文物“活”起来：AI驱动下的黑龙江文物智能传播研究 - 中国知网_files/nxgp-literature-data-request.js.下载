//获取浏览器接口参数
function getParamFromUrl (url,name) {
    var reg = new RegExp('(?:(?:&|\\?)' + name + '=([^&]*))|(?:/' + name + '/([^/]*))', 'i');
    var r = url.match(reg);
    if (r != null)
        return decodeURI(r[1] || r[2]);
    return null;
}
